# Rust build output (workspace and the excluded vela-codegen-llvm crate)
target/

# Compiled Vela artifacts (regenerable via `velac build`)
*.exe
*.ll
*.obj
*.pdb
# Files written by I/O examples (RFC-0014) — recreated on every run
examples/data/*.tmp.txt
# Browser-demo modules (regenerable via web/build.ps1)
web/*.wasm
web/*.shim.c

# Editor / tooling
editor/**/node_modules/
# Bundled LSP server binary (copied from vela-lsp/target by npm run package)
editor/vscode/server/
*.vsix

# OS noise
Thumbs.db
.DS_Store
tools/
