# Rust build output (workspace and the excluded vyrn-codegen-llvm crate)
target/

# Compiled Vyrn artifacts (regenerable via `vyrn build`)
*.exe
*.ll
*.obj
*.pdb
# Files written by I/O examples (RFC-0014) — recreated on every run
examples/data/*.tmp.txt
# Runtime store written by the `examples/bin` pastebin (persistence dogfood) —
# it is app data, not source; recreated on demand by the running server
examples/bin/data/
# Browser-demo modules (regenerable via web/build.ps1)
web/*.wasm
web/*.shim.c
# `vyrn dev` scratch: the client wasm it rebuilds on each start (RFC-0019)
.vyrn-dev/
*.wasm
*.shim.c

# Editor / tooling
editor/**/node_modules/
# Bundled LSP server binary (copied from vyrn-lsp/target by npm run package)
editor/vscode/server/
*.vsix

# OS noise
Thumbs.db
.DS_Store
tools/
