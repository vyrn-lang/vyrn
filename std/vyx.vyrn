/// std/vyx — the `.vyx` single-file component compiler (RFC-0026 M4, RFC-0039 v2),
/// a template compiler written in comptime-pure Vyrn on RFC-0021 generator imports.
/// One `gen fn`, `components(dir)`, reads every `<Name>.vyx` file in `dir` at
/// compile time (sandboxed, deterministic, cached), parses its `<script>`/
/// `<template>` sections with a real, comment/string-aware scanner (the ICU
/// parser's big sibling), and synthesizes ONE module exporting one pure view
/// function per component. The compiler knows nothing about templates — everything
/// below is plain Vyrn over `listDir`/`readFile` (RFC-0021) emitting `std/html`
/// (RFC-0026 M1) hyperscript.
///
///   import { components } from "std/vyx"
///   import { itemRow, cart } from components("./components")
///
/// This is a SIBLING file to `std/ui` (the pages router), not a section of it, on
/// purpose: the router and the template compiler are two independent libraries on
/// the same mechanism, each large enough to read on its own, and their generated
/// helpers live in separate namespaces (`ui`-prefixed vs `vyx`-prefixed) so the
/// two never intermix. `std/ui`'s `pages` calls into this file's EXPOSED PURE
/// COMPILER CORE (`vyxCompileComponent` / `vyxBuildModule`) for `.vyx`-page sugar.
///
/// A `.vyx` file has two sections:
///   <script>   — an optional `props { name: Type, … }` block (the view fn's
///                parameters), optional `import { … } from "…"` lines (passed
///                through, relative paths REBASED so they resolve from the
///                synthesized module, and DEDUPED across all components — a
///                component may import what it needs directly, RFC-0039 §3), and
///                optional plain `fn`/`let`/`type` helpers (passed through,
///                module-internal).
///   <template> — exactly ONE root element, compiled to the view fn body.
///
/// Template grammar (Vue-flavored, RFC-0039 §1):
///   {{ expr }}                  → text((expr).toString())     (always escaped)
///   v-html="expr"               → Raw(expr) as the element's content (NOT escaped)
///   <slot/>                     → splices the trailing children param
///   v-if="c" / v-else-if="c" / v-else   → nested Empty-elided conditionals (each
///                                 directive on an element; the v-else-if/v-else
///                                 element must be the immediately following
///                                 element sibling — whitespace/comments between
///                                 are fine; a dangling one is a named diagnostic)
///   v-for="x in expr"  (+ REQUIRED :key="expr")   → keyed loop
///   :name="expr"  (incl. :class, :value)          → dynamic attribute
///   name="…"                    → static attribute (`class` stays compile-checked
///                                 when themed)
///   <Capitalized :p="e" q="s"/> / <Capitalized>…</Capitalized>  → component call
///   @click="handler" / @click="handler(scalar)" (also @input/@change/@submit/…)
///                               → On(event, "handler", (scalar).toString())
///
/// Whitespace rule: an all-whitespace text run that spans a newline (indentation
/// between block tags) is dropped; a same-line whitespace run is one significant
/// inline space; other runs have their whitespace collapsed to single spaces.
/// `<!-- … -->` comments and a lone `{` in text are inert (the `{` is literal;
/// only `{{` opens an interpolation).
///
/// Every generation failure is an identifier-carrying load diagnostic naming the
/// `.vyx` file and line (the std/ui / std/rpc convention). Inspect the whole
/// synthesized module with:  vyrn emit-gen <file>

// ===========================================================================
// Byte / string helpers — all comptime-pure, legal in a `gen fn` and its callees.
// ===========================================================================

/// The bytes `ba[s..e)` as a String ("" on the impossible non-UTF-8 slice).
fn vyxSlice(ba: Array<UInt8>, s: Int64, e: Int64) -> String {
    let mut out: Array<UInt8> = []
    let mut i = s
    while i < e {
        out.push(ba[i])
        i = i + 1
    }
    return match stringFromBytes(out) {
        Ok(v) => v,
        Err(err) => "",
    }
}

/// True for an ASCII space, tab, CR, or LF.
fn vyxIsWs(b: UInt8) -> Bool {
    return b == 32 || b == 9 || b == 10 || b == 13
}

/// True for an ASCII letter, digit, or `_` (identifier bytes).
fn vyxIsIdent(b: UInt8) -> Bool {
    return (b >= 97 && b <= 122) || (b >= 65 && b <= 90) || (b >= 48 && b <= 57) || b == 95
}

/// `s` with leading and trailing ASCII whitespace removed.
fn vyxTrim(s: String) -> String {
    let ba = bytes(s)
    let mut start = 0
    let mut found = false
    let mut i = 0
    while i < ba.length && found == false {
        if vyxIsWs(ba[i]) {
            i = i + 1
        } else {
            start = i
            found = true
        }
    }
    if found == false {
        return ""
    }
    let mut end = ba.length
    let mut moving = true
    while moving {
        if end > start && vyxIsWs(ba[end - 1]) {
            end = end - 1
        } else {
            moving = false
        }
    }
    return vyxSlice(ba, start, end)
}

/// Lowercase the first ASCII byte of `s` (`ItemRow` → `itemRow`).
fn vyxLowerFirst(s: String) -> String {
    let ba = bytes(s)
    let mut out: Array<UInt8> = []
    let mut i = 0
    for b in ba {
        if i == 0 && b >= 65 && b <= 90 {
            out.push(b + 32)
        } else {
            out.push(b)
        }
        i = i + 1
    }
    return match stringFromBytes(out) {
        Ok(v) => v,
        Err(err) => s,
    }
}

/// `key` with every non-identifier byte turned into `_`, so a file path is a
/// legal identifier fragment inside a load-diagnostic name.
fn vyxIdentOf(key: String) -> String {
    let ba = bytes(key)
    let mut out: Array<UInt8> = []
    for b in ba {
        if vyxIsIdent(b) {
            out.push(b)
        } else {
            out.push(95)
        }
    }
    return match stringFromBytes(out) {
        Ok(v) => v,
        Err(err) => "id",
    }
}

/// Whether `arr` contains `x`.
fn vyxContains(arr: Array<String>, x: String) -> Bool {
    for s in arr {
        if s == x {
            return true
        }
    }
    return false
}

/// `arr` with `s` appended (value semantics — the input is unchanged).
fn vyxAppend(arr: Array<String>, s: String) -> Array<String> {
    let mut out = arr
    out.push(s)
    return out
}

/// Join `parts` with `sep` between them.
fn vyxJoin(parts: Array<String>, sep: String) -> String {
    let mut out = ""
    let mut i = 0
    for p in parts {
        if i > 0 {
            out = out + sep
        }
        out = out + p
        i = i + 1
    }
    return out
}

/// The 1-based line number of byte offset `off` within `ba` (newlines before it).
fn vyxLineAt(ba: Array<UInt8>, off: Int64) -> Int64 {
    let mut line = 1
    let mut i = 0
    while i < off && i < ba.length {
        if ba[i] == 10 {
            line = line + 1
        }
        i = i + 1
    }
    return line
}

/// The 1-based column of byte offset `off` within `ba` (chars since the last LF).
/// RFC-0033 origin directives are 1-based; this feeds their `:col` field so a
/// diagnostic in a template pass-through maps to the exact `.vyx` column.
fn vyxColAt(ba: Array<UInt8>, off: Int64) -> Int64 {
    let mut col = 1
    let mut i = off
    while i > 0 && ba[i - 1] != 10 {
        col = col + 1
        i = i - 1
    }
    return col
}

/// The byte offset of the first non-whitespace byte in `ba[from..)`, so a
/// `{{  expr }}` interpolation maps to the actual start column of `expr`.
fn vyxSkipWs(ba: Array<UInt8>, from: Int64, e: Int64) -> Int64 {
    let mut i = from
    while i < e && vyxIsWs(ba[i]) {
        i = i + 1
    }
    return i
}

// ---- emitting Vyrn source: escape a raw string as a `"…"` literal -----------

/// The second byte of a Vyrn string-literal escape for `b`, or 0 when `b` needs
/// no escaping.
fn vyxEscSecond(b: UInt8) -> UInt8 {
    if b == 92 {
        return 92
    }
    if b == 34 {
        return 34
    }
    if b == 10 {
        return 110
    }
    if b == 13 {
        return 114
    }
    if b == 9 {
        return 116
    }
    return 0
}

/// `raw` wrapped and escaped as a Vyrn string literal (quotes included). UTF-8
/// bytes pass through untouched, so template text is embedded verbatim.
fn vyxStrLit(raw: String) -> String {
    let ba = bytes(raw)
    let mut out: Array<UInt8> = []
    out.push(34)
    for b in ba {
        let s = vyxEscSecond(b)
        if s == 0 {
            out.push(b)
        } else {
            out.push(92)
            out.push(s)
        }
    }
    out.push(34)
    return match stringFromBytes(out) {
        Ok(v) => v,
        Err(err) => "\"\"",
    }
}

// ---- substring search + slicing over the raw file bytes ---------------------

/// The index of the first occurrence of `needle` in `ba` at or after `from`, or
/// -1 when absent.
fn vyxFind(ba: Array<UInt8>, needle: Array<UInt8>, from: Int64) -> Int64 {
    if needle.length == 0 {
        return from
    }
    let mut i = from
    while i + needle.length <= ba.length {
        let mut j = 0
        let mut ok = true
        while j < needle.length && ok {
            if ba[i + j] != needle[j] {
                ok = false
            }
            j = j + 1
        }
        if ok {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

/// The index of the LAST occurrence of `needle` in `ba` at or after `from`, or -1.
fn vyxFindLast(ba: Array<UInt8>, needle: Array<UInt8>, from: Int64) -> Int64 {
    let mut found = 0 - 1
    let mut at = vyxFind(ba, needle, from)
    while at >= 0 {
        found = at
        at = vyxFind(ba, needle, at + 1)
    }
    return found
}

/// Whether `s` contains an ASCII newline (LF).
fn vyxHasNewline(s: String) -> Bool {
    for b in bytes(s) {
        if b == 10 {
            return true
        }
    }
    return false
}

/// Collapse each run of ASCII whitespace in `s` to a single space (interior runs
/// become one space; a single leading/trailing space survives). An all-whitespace
/// run collapses to a single space, which the caller drops.
fn vyxCollapseWs(s: String) -> String {
    let ba = bytes(s)
    let mut out: Array<UInt8> = []
    let mut inWs = false
    for b in ba {
        if vyxIsWs(b) {
            if inWs == false {
                out.push(32)
                inWs = true
            }
        } else {
            out.push(b)
            inWs = false
        }
    }
    return match stringFromBytes(out) {
        Ok(v) => v,
        Err(err) => s,
    }
}

// ===========================================================================
// Real scanner — the section boundaries and the `props` keyword are found by a
// walk that tracks `//` line comments, `/* … */` block comments, and `"…"`
// string literals, so a match inside a comment or a string is impossible by
// construction (RFC-0039 §2). This closes six v1 byte-scan miscompiles: a comment
// (or a helper string, or a helper identifier) mentioning `props`/`template`/
// `script`, an HTML comment in the template, a lone `{` in text, and a literal
// `</script>`/`<template>` inside a helper string.
// ===========================================================================

/// The index of the first `needle` in `ba` at or after `from` that lies OUTSIDE a
/// `"…"` string, a `//` line comment, or a `/* … */` block comment; `codeMode`
/// enables the two comment kinds (a `<template>` body has no `//` comments, so it
/// scans string-aware only). Returns -1 when `needle` never occurs in code.
fn vyxScanFindCode(ba: Array<UInt8>, needle: Array<UInt8>, from: Int64, codeMode: Bool) -> Int64 {
    let mut i = from
    let n = needle.length
    while i < ba.length {
        let b = ba[i]
        if b == 34 {
            // A `"…"` string literal: skip to the unescaped closing quote.
            i = i + 1
            while i < ba.length && ba[i] != 34 {
                if ba[i] == 92 {
                    i = i + 1
                }
                i = i + 1
            }
            i = i + 1
        } else if codeMode && b == 47 && i + 1 < ba.length && ba[i + 1] == 47 {
            // A `//` line comment: skip to the next LF.
            i = i + 2
            while i < ba.length && ba[i] != 10 {
                i = i + 1
            }
        } else if codeMode && b == 47 && i + 1 < ba.length && ba[i + 1] == 42 {
            // A `/* … */` block comment: skip to the closing `*/`.
            i = i + 2
            while i + 1 < ba.length && !(ba[i] == 42 && ba[i + 1] == 47) {
                i = i + 1
            }
            i = i + 2
        } else {
            // Try to match `needle` here.
            let mut j = 0
            let mut ok = true
            while j < n && ok {
                if i + j >= ba.length || ba[i + j] != needle[j] {
                    ok = false
                }
                j = j + 1
            }
            if ok && n > 0 {
                return i
            }
            i = i + 1
        }
    }
    return 0 - 1
}

// ===========================================================================
// The template AST — a self-recursive node tree. All line numbers are ABSOLUTE
// byte-line positions in the `.vyx` file, so diagnostics and emit-gen origin
// comments name the source line.
// ===========================================================================

/// One attribute on a template element. `dyn` = a `:name="expr"` dynamic value;
/// `evt` = an `@event` binding (its `name` has the `@` stripped). A `v-…`
/// directive is carried as a plain attribute whose `name` retains the `v-` prefix
/// (`dyn` false, since its value is written as a quoted string) and is consumed by
/// the grouping pass. `line`/`col` are the 1-based position of the attribute value
/// in the `.vyx` file (RFC-0033 origins).
type VyxAttr = { name: String, value: String, dyn: Bool, evt: Bool, line: Int64, col: Int64 }

/// A node in a parsed template. The trailing `Int64` pair on position-bearing
/// variants is the 1-based `(line, col)` of the pass-through in the `.vyx` file,
/// so RFC-0033 origin directives point at the exact source column. `VNIf` carries
/// PARALLEL per-condition `(line, col)` arrays so each `v-if`/`v-else-if` maps to
/// its own condition column.
type VyxNode =
    | VNText(String)
    | VNInterp(String, Int64, Int64)
    | VNRaw(String, Int64, Int64)
    | VNChildren
    | VNElem(String, Bool, Array<VyxAttr>, Array<VyxNode>, Int64)
    | VNIf(Array<String>, Array<Int64>, Array<Int64>, Array<VyxBody>, VyxBody, Bool)
    | VNFor(String, String, String, Array<VyxNode>, Int64, Int64)

/// A node-list wrapper, so an `Array<VyxNode>` can nest inside another node's
/// payload (an if-chain's per-branch bodies) without an `Array<Array<…>>`.
type VyxBody = { nodes: Array<VyxNode> }

// ===========================================================================
// Interpolation reader — a `{{ expr }}` token (quote-aware, so a `}}` inside an
// expression string literal does not close the interpolation early).
// ===========================================================================

/// The index just past the `}}` closing the interpolation whose `{{` is at `open`.
/// Skips `"…"` string literals (with `\"` escapes) so their braces are ignored.
/// Returns `e` (no match) when the interpolation is unterminated.
fn vyxMatchInterp(ba: Array<UInt8>, open: Int64, e: Int64) -> Int64 {
    let mut i = open + 2
    while i < e {
        let b = ba[i]
        if b == 34 {
            i = i + 1
            while i < e && ba[i] != 34 {
                if ba[i] == 92 {
                    i = i + 1
                }
                i = i + 1
            }
            i = i + 1
        } else if b == 125 && i + 1 < e && ba[i + 1] == 125 {
            return i + 2
        } else {
            i = i + 1
        }
    }
    return e
}

/// The index just past the `"` closing the string literal whose `"` is at `q`.
fn vyxScanQuote(ba: Array<UInt8>, q: Int64, e: Int64) -> Int64 {
    let mut i = q + 1
    while i < e && ba[i] != 34 {
        if ba[i] == 92 {
            i = i + 1
        }
        i = i + 1
    }
    return i + 1
}

/// The index just past the delimiter closing the attribute value whose opening
/// delimiter (`"` or `'`) is at `q`. Single-quoted attribute values (RFC-0039 §1,
/// the Vue convention) let an expression carry Vyrn `"…"` string literals:
/// `:href='"/raw/" + p.id'`.
fn vyxScanAttrValue(ba: Array<UInt8>, q: Int64, e: Int64) -> Int64 {
    let delim = ba[q]
    let mut i = q + 1
    while i < e && ba[i] != delim {
        if ba[i] == 92 {
            i = i + 1
        }
        i = i + 1
    }
    return i + 1
}

// ===========================================================================
// The parser — recursive descent over the template section. `vyxParseNodes` reads
// a run of sibling nodes until a `</…>` close tag (leaving `next` AT it for the
// caller). `v-if`/`v-for` are ordinary element attributes here; the grouping pass
// (below) turns sibling `v-if` chains into `VNIf` and `v-for` elements into
// `VNFor`.
// ===========================================================================

/// The result of parsing a run of sibling nodes.
type VyxParse = { nodes: Array<VyxNode>, next: Int64, stop: String, err: String }

/// The result of parsing one element's or component's opening tag attributes.
type VyxAttrs = { attrs: Array<VyxAttr>, next: Int64, selfClose: Bool, err: String }

/// A tag name plus whether its first letter is uppercase (a component).
type VyxTag = { name: String, isComp: Bool, next: Int64 }

/// Read a tag name starting at `i` (just past `<`).
fn vyxReadTagName(ba: Array<UInt8>, i: Int64, e: Int64) -> VyxTag {
    let mut j = i
    while j < e && (vyxIsIdent(ba[j]) || ba[j] == 45) {
        j = j + 1
    }
    let name = vyxSlice(ba, i, j)
    let isComp = name.length > 0 && bytes(name)[0] >= 65 && bytes(name)[0] <= 90
    return VyxTag { name: name, isComp: isComp, next: j }
}

/// A load-diagnostic identifier line (parsing it fails, naming the offense).
fn vyxErr(tag: String, fileId: String, line: Int64) -> String {
    return tag + "__" + fileId + "__line_" + line.toString() + "\n"
}

/// A load-diagnostic identifier line with an extra detail fragment.
fn vyxErrDetail(tag: String, fileId: String, line: Int64, detail: String) -> String {
    return tag + "__" + fileId + "__line_" + line.toString() + "__" + vyxIdentOf(detail) + "\n"
}

/// Parse a tag's attributes, starting at `i` (just past the tag name), up to the
/// closing `>` or `/>`. A `:name` attribute is dynamic (`dyn`, `:` stripped); an
/// `@event` attribute is an event binding (`evt`, `@` stripped); everything else
/// (including a `v-…` directive) is a plain attribute with a quoted or absent
/// value.
fn vyxParseAttrs(ba: Array<UInt8>, i: Int64, e: Int64, fileId: String) -> VyxAttrs {
    let mut attrs: Array<VyxAttr> = []
    let mut j = i
    while j < e {
        while j < e && vyxIsWs(ba[j]) {
            j = j + 1
        }
        if j >= e {
            return VyxAttrs { attrs: attrs, next: j, selfClose: false, err: vyxErr("VYX_UNCLOSED_TAG", fileId, vyxLineAt(ba, i)) }
        }
        if ba[j] == 62 {
            return VyxAttrs { attrs: attrs, next: j + 1, selfClose: false, err: "" }
        }
        if ba[j] == 47 {
            if j + 1 < e && ba[j + 1] == 62 {
                return VyxAttrs { attrs: attrs, next: j + 2, selfClose: true, err: "" }
            }
            j = j + 1
        } else {
            let attrLine = vyxLineAt(ba, j)
            let evt = ba[j] == 64
            let dynMark = ba[j] == 58
            let nameStart = if evt || dynMark { j + 1 } else { j }
            let mut k = nameStart
            while k < e && (vyxIsIdent(ba[k]) || ba[k] == 45) {
                k = k + 1
            }
            let name = vyxSlice(ba, nameStart, k)
            // Skip whitespace before a possible `=`.
            let mut m = k
            while m < e && vyxIsWs(ba[m]) {
                m = m + 1
            }
            if m < e && ba[m] == 61 {
                m = m + 1
                while m < e && vyxIsWs(ba[m]) {
                    m = m + 1
                }
                if m < e && (ba[m] == 34 || ba[m] == 39) {
                    // `"…"` or `'…'` — single quotes (the Vue convention) let the
                    // value expression carry Vyrn `"…"` string literals.
                    let vEnd = vyxScanAttrValue(ba, m, e)
                    let valStart = vyxSkipWs(ba, m + 1, vEnd - 1)
                    attrs.push(VyxAttr { name: name, value: vyxTrim(vyxSlice(ba, m + 1, vEnd - 1)), dyn: dynMark, evt: evt, line: vyxLineAt(ba, valStart), col: vyxColAt(ba, valStart) })
                    j = vEnd
                } else {
                    return VyxAttrs { attrs: attrs, next: m, selfClose: false, err: vyxErr("VYX_BAD_ATTR_VALUE", fileId, attrLine) }
                }
            } else {
                // A valueless attribute (`disabled`, `v-else`) renders as `name=""`.
                attrs.push(VyxAttr { name: name, value: "", dyn: dynMark, evt: evt, line: attrLine, col: vyxColAt(ba, nameStart) })
                j = k
            }
        }
    }
    return VyxAttrs { attrs: attrs, next: j, selfClose: false, err: vyxErr("VYX_UNCLOSED_TAG", fileId, vyxLineAt(ba, i)) }
}

/// Parse a run of sibling nodes from `i` up to a `</…>` close tag. Elements carry
/// their `v-…` directives as attributes; the grouping pass consumes them.
fn vyxParseNodes(ba: Array<UInt8>, i: Int64, e: Int64, fileId: String) -> VyxParse {
    let mut nodes: Array<VyxNode> = []
    let mut j = i
    while j < e {
        let b = ba[j]
        if b == 60 {
            // `<!-- … -->` comment: inert, produces no node.
            if j + 3 < e && ba[j + 1] == 33 && ba[j + 2] == 45 && ba[j + 3] == 45 {
                let close = vyxFind(ba, bytes("-->"), j + 4)
                if close < 0 {
                    j = e
                } else {
                    j = close + 3
                }
            } else if j + 1 < e && ba[j + 1] == 47 {
                // A closing `</…>` belongs to the caller.
                return VyxParse { nodes: nodes, next: j, stop: "close", err: "" }
            } else {
                let er = vyxParseElem(ba, j, e, fileId)
                if er.err != "" {
                    return VyxParse { nodes: nodes, next: er.next, stop: "", err: er.err }
                }
                nodes.push(er.node)
                j = er.next
            }
        } else if b == 123 && j + 1 < e && ba[j + 1] == 123 {
            // `{{ expr }}` interpolation.
            let close = vyxMatchInterp(ba, j, e)
            if close > e || (close == e && (e < 2 || ba[e - 1] != 125 || ba[e - 2] != 125)) {
                return VyxParse { nodes: nodes, next: j, stop: "", err: vyxErr("VYX_UNTERMINATED_INTERP", fileId, vyxLineAt(ba, j)) }
            }
            let exprAt = vyxSkipWs(ba, j + 2, close - 2)
            let expr = vyxTrim(vyxSlice(ba, j + 2, close - 2))
            if expr.length == 0 {
                return VyxParse { nodes: nodes, next: j, stop: "", err: vyxErr("VYX_EMPTY_INTERP", fileId, vyxLineAt(ba, j)) }
            }
            nodes.push(VNInterp(expr, vyxLineAt(ba, exprAt), vyxColAt(ba, exprAt)))
            j = close
        } else {
            // A literal text run up to the next `<` or `{{`. A lone `{` is text.
            let mut k = j
            while k < e && ba[k] != 60 && !(ba[k] == 123 && k + 1 < e && ba[k + 1] == 123) {
                k = k + 1
            }
            let raw = vyxSlice(ba, j, k)
            // Whitespace rule (see the file header): an all-whitespace run that
            // spans a newline is insignificant indentation and is dropped; a
            // same-line whitespace run is one significant inline space; any other
            // run has its whitespace collapsed to single spaces.
            if vyxTrim(raw).length == 0 {
                if vyxHasNewline(raw) == false && raw.length > 0 {
                    nodes.push(VNText(" "))
                }
            } else {
                nodes.push(VNText(vyxCollapseWs(raw)))
            }
            j = k
        }
    }
    return VyxParse { nodes: nodes, next: j, stop: "", err: "" }
}

/// One parsed node plus the index past it.
type VyxNodeR = { node: VyxNode, next: Int64, err: String }

/// Parse one element or component starting at `<` (`i`). A `<slot/>` (or
/// `<slot></slot>`) parses to `VNChildren`.
fn vyxParseElem(ba: Array<UInt8>, i: Int64, e: Int64, fileId: String) -> VyxNodeR {
    let line = vyxLineAt(ba, i)
    let tag = vyxReadTagName(ba, i + 1, e)
    if tag.name.length == 0 {
        return VyxNodeR { node: VNText(""), next: e, err: vyxErr("VYX_BAD_TAG", fileId, line) }
    }
    let pa = vyxParseAttrs(ba, tag.next, e, fileId)
    if pa.err != "" {
        return VyxNodeR { node: VNText(""), next: pa.next, err: pa.err }
    }
    let isSlot = tag.name == "slot"
    if pa.selfClose {
        if isSlot {
            return VyxNodeR { node: VNChildren, next: pa.next, err: "" }
        }
        return VyxNodeR { node: VNElem(tag.name, tag.isComp, pa.attrs, [], line), next: pa.next, err: "" }
    }
    // Paired tag: parse children, then require the matching close tag.
    let kids = vyxParseNodes(ba, pa.next, e, fileId)
    if kids.err != "" {
        return VyxNodeR { node: VNText(""), next: kids.next, err: kids.err }
    }
    if kids.stop != "close" {
        return VyxNodeR { node: VNText(""), next: kids.next, err: vyxErrDetail("VYX_UNCLOSED_ELEMENT", fileId, line, tag.name) }
    }
    // Consume `</name>`.
    let ct = vyxReadTagName(ba, kids.next + 2, e)
    if ct.name != tag.name {
        return VyxNodeR { node: VNText(""), next: kids.next, err: vyxErrDetail("VYX_MISMATCHED_TAG", fileId, line, tag.name + "_vs_" + ct.name) }
    }
    let mut m = ct.next
    while m < e && ba[m] != 62 {
        m = m + 1
    }
    if isSlot {
        return VyxNodeR { node: VNChildren, next: m + 1, err: "" }
    }
    return VyxNodeR { node: VNElem(tag.name, tag.isComp, pa.attrs, kids.nodes, line), next: m + 1, err: "" }
}

// ===========================================================================
// The grouping pass — turn the flat sibling list (elements carrying `v-…`
// directives) into the control-flow AST: a `v-if`/`v-else-if`/`v-else` sibling
// chain becomes one `VNIf`, a `v-for` element becomes a `VNFor`, and a `v-html`
// element's content becomes a single `VNRaw`. RFC-0039 §1 lowering is UNCHANGED
// from v1 (`Empty`-elided chains, `map` + `keyed`); only the surface differs.
// ===========================================================================

/// A directive lookup result: the directive's value plus its 1-based position.
type VyxDir = { found: Bool, value: String, line: Int64, col: Int64 }

/// Look up directive/attribute `name` (exact, non-event) on `attrs`.
fn vyxDir(attrs: Array<VyxAttr>, name: String) -> VyxDir {
    for a in attrs {
        if a.evt == false && a.name == name {
            return VyxDir { found: true, value: a.value, line: a.line, col: a.col }
        }
    }
    return VyxDir { found: false, value: "", line: 0, col: 0 }
}

/// `attrs` with the structural directives (`v-if`/`v-else-if`/`v-else`/`v-for`/
/// `v-html`, and `key` when `dropKey`) removed, so the emitted element carries
/// only its real attributes.
fn vyxStripDirectives(attrs: Array<VyxAttr>, dropKey: Bool) -> Array<VyxAttr> {
    let mut out: Array<VyxAttr> = []
    for a in attrs {
        let structural = a.name == "v-if" || a.name == "v-else-if" || a.name == "v-else" || a.name == "v-for" || a.name == "v-html"
        let isKey = dropKey && a.evt == false && a.name == "key"
        if structural == false && isKey == false {
            out.push(a)
        }
    }
    return out
}

/// A parsed `v-for` header: loop variable and iterable expression from `x in expr`.
type VyxForHdr = { var: String, iter: String, err: String }

/// Parse a `v-for` header `x in <iterexpr>` into (var, iter).
fn vyxParseForHead(header: String, fileId: String, line: Int64) -> VyxForHdr {
    let ba = bytes(header)
    let mut i = 0
    while i < ba.length && vyxIsWs(ba[i]) {
        i = i + 1
    }
    let vStart = i
    while i < ba.length && vyxIsIdent(ba[i]) {
        i = i + 1
    }
    let varName = vyxSlice(ba, vStart, i)
    while i < ba.length && vyxIsWs(ba[i]) {
        i = i + 1
    }
    // Expect the `in` keyword as a standalone token.
    if i + 1 >= ba.length || ba[i] != 105 || ba[i + 1] != 110 {
        return VyxForHdr { var: "", iter: "", err: vyxErr("VYX_BAD_FOR_HEADER", fileId, line) }
    }
    if i + 2 < ba.length && vyxIsWs(ba[i + 2]) == false {
        return VyxForHdr { var: "", iter: "", err: vyxErr("VYX_BAD_FOR_HEADER", fileId, line) }
    }
    let iter = vyxTrim(vyxSlice(ba, i + 2, ba.length))
    if varName.length == 0 || iter.length == 0 {
        return VyxForHdr { var: varName, iter: iter, err: vyxErr("VYX_BAD_FOR_HEADER", fileId, line) }
    }
    return VyxForHdr { var: varName, iter: iter, err: "" }
}

/// A grouped node result.
type VyxGroup = { nodes: Array<VyxNode>, err: String }

/// A single processed node result.
type VyxOne = { node: VyxNode, err: String }

/// Whether text node `n` is whitespace-only (so it may sit between chained
/// `v-if`/`v-else-if`/`v-else` siblings without breaking the chain).
fn vyxIsWsText(n: VyxNode) -> Bool {
    return match n {
        VNText(s) => vyxTrim(s).length == 0,
        VNInterp(x, l, c) => false,
        VNRaw(x, l, c) => false,
        VNChildren => false,
        VNElem(t, cc, a, k, l) => false,
        VNIf(cs, cl, cc, bs, e, h) => false,
        VNFor(v, it, k, bd, l, c) => false,
    }
}

/// Whether raw node `n` is an element carrying directive `name`.
fn vyxElemHasDir(n: VyxNode, name: String) -> Bool {
    return match n {
        VNElem(t, cc, a, k, l) => vyxDir(a, name).found,
        VNText(s) => false,
        VNInterp(x, l, c) => false,
        VNRaw(x, l, c) => false,
        VNChildren => false,
        VNIf(cs, cl, ccc, bs, e, h) => false,
        VNFor(v, it, kk, bd, l, c) => false,
    }
}

/// Process ONE raw element into its final node — recurse into children, apply
/// `v-html`, and wrap a `v-for` element into `VNFor` (its required `:key`).
fn vyxProcessElem(n: VyxNode, fileId: String) -> VyxOne {
    return match n {
        VNElem(tag, isComp, attrs, kids, line) => vyxProcessElemInner(tag, isComp, attrs, kids, line, fileId),
        VNText(s) => VyxOne { node: n, err: "" },
        VNInterp(x, l, c) => VyxOne { node: n, err: "" },
        VNRaw(x, l, c) => VyxOne { node: n, err: "" },
        VNChildren => VyxOne { node: n, err: "" },
        VNIf(cs, cl, cc, bs, e, h) => VyxOne { node: n, err: "" },
        VNFor(v, it, k, bd, l, c) => VyxOne { node: n, err: "" },
    }
}

fn vyxProcessElemInner(tag: String, isComp: Bool, attrs: Array<VyxAttr>, kids: Array<VyxNode>, line: Int64, fileId: String) -> VyxOne {
    // v-html replaces the element content with a single Raw node.
    let vhtml = vyxDir(attrs, "v-html")
    let mut childNodes = kids
    let mut err = ""
    if vhtml.found {
        childNodes = [VNRaw(vhtml.value, vhtml.line, vhtml.col)]
    } else {
        let g = vyxGroupNodes(kids, fileId)
        childNodes = g.nodes
        err = err + g.err
    }
    let vfor = vyxDir(attrs, "v-for")
    if vfor.found {
        let key = vyxDir(attrs, "key")
        if key.found == false {
            err = err + vyxErr("VYX_MISSING_FOR_KEY", fileId, line)
        }
        let h = vyxParseForHead(vfor.value, fileId, vfor.line)
        err = err + h.err
        let elem = VNElem(tag, isComp, vyxStripDirectives(attrs, true), childNodes, line)
        return VyxOne { node: VNFor(h.var, h.iter, key.value, [elem], vfor.line, vfor.col), err: err }
    }
    return VyxOne { node: VNElem(tag, isComp, vyxStripDirectives(attrs, false), childNodes, line), err: err }
}

/// Group a flat sibling list into the control-flow AST.
fn vyxGroupNodes(nodes: Array<VyxNode>, fileId: String) -> VyxGroup {
    let mut out: Array<VyxNode> = []
    let mut err = ""
    let mut i = 0
    while i < nodes.length {
        let n = nodes[i]
        if vyxElemHasDir(n, "v-if") {
            // Start an if-chain. The head element is the first branch.
            let mut conds: Array<String> = []
            let mut condLines: Array<Int64> = []
            let mut condCols: Array<Int64> = []
            let mut bodies: Array<VyxBody> = []
            let mut elseBody = VyxBody { nodes: [] }
            let mut hasElse = false
            let vif = vyxAttrsOf(n)
            let d = vyxDir(vif, "v-if")
            conds.push(d.value)
            condLines.push(d.line)
            condCols.push(d.col)
            let p0 = vyxProcessElem(n, fileId)
            err = err + p0.err
            bodies.push(VyxBody { nodes: [p0.node] })
            // Consume following siblings (skipping whitespace-only text) that carry
            // v-else-if / v-else.
            let mut k = i + 1
            let mut chaining = true
            while chaining && k < nodes.length {
                if vyxIsWsText(nodes[k]) {
                    k = k + 1
                } else if vyxElemHasDir(nodes[k], "v-else-if") {
                    let de = vyxDir(vyxAttrsOf(nodes[k]), "v-else-if")
                    conds.push(de.value)
                    condLines.push(de.line)
                    condCols.push(de.col)
                    let pe = vyxProcessElem(nodes[k], fileId)
                    err = err + pe.err
                    bodies.push(VyxBody { nodes: [pe.node] })
                    k = k + 1
                } else if vyxElemHasDir(nodes[k], "v-else") {
                    let pl = vyxProcessElem(nodes[k], fileId)
                    err = err + pl.err
                    elseBody = VyxBody { nodes: [pl.node] }
                    hasElse = true
                    k = k + 1
                    chaining = false
                } else {
                    chaining = false
                }
            }
            out.push(VNIf(conds, condLines, condCols, bodies, elseBody, hasElse))
            i = k
        } else if vyxElemHasDir(n, "v-else-if") {
            err = err + vyxErr("VYX_DANGLING_ELSE_IF", fileId, vyxElemLine(n))
            i = i + 1
        } else if vyxElemHasDir(n, "v-else") {
            err = err + vyxErr("VYX_DANGLING_ELSE", fileId, vyxElemLine(n))
            i = i + 1
        } else {
            let p = vyxProcessElem(n, fileId)
            err = err + p.err
            out.push(p.node)
            i = i + 1
        }
    }
    return VyxGroup { nodes: out, err: err }
}

/// The attributes of an element node (empty for a non-element).
fn vyxAttrsOf(n: VyxNode) -> Array<VyxAttr> {
    return match n {
        VNElem(t, cc, a, k, l) => a,
        VNText(s) => [],
        VNInterp(x, l, c) => [],
        VNRaw(x, l, c) => [],
        VNChildren => [],
        VNIf(cs, cl, ccc, bs, e, h) => [],
        VNFor(v, it, kk, bd, l, c) => [],
    }
}

/// The source line of an element node (0 for a non-element).
fn vyxElemLine(n: VyxNode) -> Int64 {
    return match n {
        VNElem(t, cc, a, k, l) => l,
        VNText(s) => 0,
        VNInterp(x, l, c) => l,
        VNRaw(x, l, c) => l,
        VNChildren => 0,
        VNIf(cs, cl, ccc, bs, e, h) => 0,
        VNFor(v, it, kk, bd, l, c) => l,
    }
}

// ===========================================================================
// Section extraction + script parsing.
// ===========================================================================

/// A section's content bounds within the file (`found=false` when absent).
type VyxSection = { found: Bool, start: Int64, end: Int64 }

/// The content bounds of `<name> … </name>` in `ba` (between the open tag's `>`
/// and the closing tag's `<`), found with the comment/string-aware scanner so a
/// literal `</script>` inside a helper string never truncates the section
/// (RFC-0039 §2). The `<script>` body scans in code mode; `<template>` scans
/// string-aware only (its content has no `//` comments).
fn vyxSection(ba: Array<UInt8>, name: String, codeMode: Bool) -> VyxSection {
    return vyxSectionAvoid(ba, name, codeMode, 0 - 1, 0 - 1)
}

/// `vyxSection` with an avoid range: an open tag inside `[avoidS, avoidE)` is
/// skipped, so a literal `<template>` inside a script helper string never claims
/// the template section (the caller passes the script section's bounds).
fn vyxSectionAvoid(ba: Array<UInt8>, name: String, codeMode: Bool, avoidS: Int64, avoidE: Int64) -> VyxSection {
    let openPat = bytes("<" + name + ">")
    let mut from = 0
    let mut openAt = 0 - 1
    let mut searching = true
    while searching {
        let at = vyxFind(ba, openPat, from)
        if at < 0 {
            searching = false
        } else if avoidS >= 0 && at >= avoidS && at < avoidE {
            from = at + 1
        } else {
            openAt = at
            searching = false
        }
    }
    if openAt < 0 {
        return VyxSection { found: false, start: 0, end: 0 }
    }
    let contentStart = openAt + name.length + 2
    let closeAt = vyxScanFindCode(ba, bytes("</" + name + ">"), contentStart, codeMode)
    if closeAt < 0 {
        return VyxSection { found: false, start: 0, end: 0 }
    }
    return VyxSection { found: true, start: contentStart, end: closeAt }
}

/// The parsed `<script>` section: props (parallel name/type arrays), rebased
/// import lines, and pass-through helper source. `err` is set on a props fault.
type VyxScript = {
    propNames: Array<String>,
    propTypes: Array<String>,
    imports: Array<String>,
    helpers: String,
    err: String,
}

/// Split a record body on commas at generic (`<>`) depth 0.
fn vyxSplitFields(body: String) -> Array<String> {
    let ba = bytes(body)
    let mut parts: Array<String> = []
    let mut depth = 0
    let mut start = 0
    let mut i = 0
    while i < ba.length {
        let b = ba[i]
        if b == 60 {
            depth = depth + 1
        } else if b == 62 {
            depth = depth - 1
        } else if b == 44 && depth == 0 {
            parts.push(vyxSlice(ba, start, i))
            start = i + 1
        }
        i = i + 1
    }
    parts.push(vyxSlice(ba, start, ba.length))
    return parts
}

/// Rebase one `import … from "spec"` line: a relative `spec` (`./` or `../`) is
/// prefixed with `dir` so it resolves from the synthesized module (whose imports
/// resolve against the app file, not the `.vyx` file); bare specifiers (`std/…`,
/// `github:…`) pass through unchanged. A generator import `… from gen("./x")`
/// rebases the generator's path ARGUMENT the same way (it too resolves relative to
/// the module) — the first quoted string after ` from ` is the target.
fn vyxRebaseImport(line: String, dir: String) -> String {
    let ba = bytes(line)
    let fromAt = vyxFind(ba, bytes(" from "), 0)
    if fromAt < 0 {
        return line
    }
    let q1 = vyxFind(ba, bytes("\""), fromAt)
    if q1 < 0 {
        return line
    }
    let q2 = vyxFind(ba, bytes("\""), q1 + 1)
    if q2 < 0 {
        return line
    }
    let spec = vyxSlice(ba, q1 + 1, q2)
    if spec.startsWith("./") || spec.startsWith("../") {
        let rebased = dir + "/" + spec
        return vyxSlice(ba, 0, q1 + 1) + rebased + vyxSlice(ba, q2, ba.length)
    }
    return line
}

/// A located `props` block. `found` is set when a STATEMENT-LEADING `props`
/// keyword (the first non-whitespace token on its line, in code — never inside a
/// comment/string, never a helper identifier like `let props = …`) is seen;
/// `malformed` when that `props` is not followed by `{`. `braceAt` is the opening
/// `{` (valid only when found and not malformed). RFC-0039 §2.
type VyxProps = { found: Bool, malformed: Bool, kwAt: Int64, braceAt: Int64 }

/// Whether only whitespace lies between the byte before `at` and the previous LF
/// (so `props` is the first token on its line, distinguishing a statement-leading
/// `props {` block from a helper identifier `let props = …`).
fn vyxLineLeading(ba: Array<UInt8>, at: Int64) -> Bool {
    let mut i = at
    while i > 0 && ba[i - 1] != 10 {
        if vyxIsWs(ba[i - 1]) == false {
            return false
        }
        i = i - 1
    }
    return true
}

fn vyxFindPropsBlock(ba: Array<UInt8>) -> VyxProps {
    return vyxFindKwBlock(ba, "props")
}

/// The generalized statement-leading `<kw> { … }` block finder (see
/// `vyxFindPropsBlock`) — used for `props` in components and `params` in `.vyx`
/// pages (RFC-0039 §4).
fn vyxFindKwBlock(ba: Array<UInt8>, kwStr: String) -> VyxProps {
    let kw = bytes(kwStr)
    let mut from = 0
    let mut searching = true
    while searching {
        let at = vyxScanFindCode(ba, kw, from, true)
        if at < 0 {
            searching = false
        } else {
            let afterAt = at + kw.length
            let boundary = afterAt >= ba.length || vyxIsWs(ba[afterAt]) || ba[afterAt] == 123
            if boundary && vyxLineLeading(ba, at) {
                // A statement-leading `props` token: its block if followed by `{`,
                // else a malformed props block.
                let mut m = afterAt
                while m < ba.length && vyxIsWs(ba[m]) {
                    m = m + 1
                }
                if m < ba.length && ba[m] == 123 {
                    return VyxProps { found: true, malformed: false, kwAt: at, braceAt: m }
                }
                return VyxProps { found: true, malformed: true, kwAt: at, braceAt: 0 - 1 }
            }
            from = at + 1
        }
    }
    return VyxProps { found: false, malformed: false, kwAt: 0 - 1, braceAt: 0 - 1 }
}

/// The index just past the `}` matching the `{` at `open` (brace-depth match,
/// string-aware).
fn vyxMatchCurly(ba: Array<UInt8>, open: Int64) -> Int64 {
    let mut depth = 0
    let mut i = open
    while i < ba.length {
        let b = ba[i]
        if b == 34 {
            i = vyxScanQuote(ba, i, ba.length)
        } else if b == 123 {
            depth = depth + 1
            i = i + 1
        } else if b == 125 {
            depth = depth - 1
            i = i + 1
            if depth == 0 {
                return i
            }
        } else {
            i = i + 1
        }
    }
    return ba.length
}

/// The 1-based FILE line of the first `import …` statement in the script section
/// `[sStart, sEnd)` that begins AFTER the statement-leading `kwStr` (`props` /
/// `params`) block — i.e. an import placed after the block, violating the
/// imports-first rule (RFC-0040 §3). Returns 0 when no such block exists or every
/// import correctly precedes it. Offsets are whole-file, so the line names the
/// `.vyx` source directly.
fn vyxImportsFirstViolation(ba: Array<UInt8>, sStart: Int64, sEnd: Int64, kwStr: String) -> Int64 {
    let kw = bytes(kwStr)
    // Find the statement-leading block keyword inside the section (code-aware, so a
    // match in a comment/string/helper identifier never counts).
    let mut kwAt = 0 - 1
    let mut from = sStart
    let mut scanning = true
    while scanning {
        let at = vyxScanFindCode(ba, kw, from, true)
        if at < 0 || at >= sEnd {
            scanning = false
        } else {
            let afterAt = at + kw.length
            let boundary = afterAt >= ba.length || vyxIsWs(ba[afterAt]) || ba[afterAt] == 123
            if boundary && vyxLineLeading(ba, at) {
                kwAt = at
                scanning = false
            } else {
                from = at + 1
            }
        }
    }
    if kwAt < 0 {
        return 0
    }
    // Any `import` line whose first byte lies after the block keyword is misordered.
    let mut lineStart = sStart
    let mut i = sStart
    while i <= sEnd {
        if i == sEnd || ba[i] == 10 {
            if lineStart > kwAt {
                let t = vyxTrim(vyxSlice(ba, lineStart, i))
                if t.startsWith("import ") {
                    return vyxLineAt(ba, lineStart)
                }
            }
            lineStart = i + 1
        }
        i = i + 1
    }
    return 0
}

/// Parse the `<script>` section text: pull the single `props {…}` block, collect
/// (and rebase) import lines, and pass everything else through as helper source.
fn vyxParseScript(script: String, dir: String, fileId: String) -> VyxScript {
    let ba = bytes(script)
    let props = vyxFindPropsBlock(ba)
    let mut propNames: Array<String> = []
    let mut propTypes: Array<String> = []
    let mut bodyEnd = 0 - 1
    let mut bodyStart = 0 - 1
    if props.found {
        if props.malformed {
            return vyxScriptErr(vyxErr("VYX_BAD_PROPS", fileId, 0))
        }
        bodyStart = props.braceAt
        bodyEnd = vyxMatchCurly(ba, bodyStart)
        // A second props block is an error.
        let more = vyxFindPropsBlockFrom(ba, bodyEnd)
        if more.found {
            return vyxScriptErr(vyxErr("VYX_MULTIPLE_PROPS", fileId, 0))
        }
        let fields = vyxSplitFields(vyxSlice(ba, bodyStart + 1, bodyEnd - 1))
        for part in fields {
            let trimmed = vyxTrim(part)
            if trimmed.length > 0 {
                let pb = bytes(trimmed)
                let mut colon = 0 - 1
                let mut k = 0
                while k < pb.length && colon < 0 {
                    if pb[k] == 58 {
                        colon = k
                    }
                    k = k + 1
                }
                if colon < 0 {
                    return vyxScriptErr(vyxErr("VYX_BAD_PROPS", fileId, 0))
                }
                propNames.push(vyxTrim(vyxSlice(pb, 0, colon)))
                propTypes.push(vyxTrim(vyxSlice(pb, colon + 1, pb.length)))
            }
        }
    }
    // The rest of the script, with the props block sliced out.
    let mut rest = script
    if bodyStart >= 0 {
        rest = vyxSlice(ba, 0, props.kwAt) + vyxSlice(ba, bodyEnd, ba.length)
    }
    // Line-wise: `import` lines (rebased) vs. pass-through helpers.
    let mut imports: Array<String> = []
    let mut helpers = ""
    for line in vyxLines(rest) {
        let t = vyxTrim(line)
        if t.startsWith("import ") {
            imports.push(vyxRebaseImport(t, dir))
        } else if t.length > 0 {
            helpers = helpers + line + "\n"
        }
    }
    return VyxScript { propNames: propNames, propTypes: propTypes, imports: imports, helpers: helpers, err: "" }
}

/// A `props` block search starting at `from` (for the second-block check).
fn vyxFindPropsBlockFrom(ba: Array<UInt8>, from: Int64) -> VyxProps {
    let mut sub: Array<UInt8> = []
    let mut i = from
    while i < ba.length {
        sub.push(ba[i])
        i = i + 1
    }
    let r = vyxFindPropsBlock(sub)
    if r.found {
        let braceAt = if r.braceAt < 0 { 0 - 1 } else { r.braceAt + from }
        return VyxProps { found: true, malformed: r.malformed, kwAt: r.kwAt + from, braceAt: braceAt }
    }
    return r
}

/// A `VyxScript` carrying only an error.
fn vyxScriptErr(err: String) -> VyxScript {
    return VyxScript { propNames: [], propTypes: [], imports: [], helpers: "", err: err }
}

/// Split `s` into lines (LF-separated, CR stripped).
fn vyxLines(s: String) -> Array<String> {
    let ba = bytes(s)
    let mut lines: Array<String> = []
    let mut start = 0
    let mut i = 0
    while i < ba.length {
        if ba[i] == 10 {
            let mut end = i
            if end > start && ba[end - 1] == 13 {
                end = end - 1
            }
            lines.push(vyxSlice(ba, start, end))
            start = i + 1
        }
        i = i + 1
    }
    if start < ba.length {
        lines.push(vyxSlice(ba, start, ba.length))
    }
    return lines
}

// ===========================================================================
// A compiled component — the intermediate the assembler emits from.
// ===========================================================================

/// One parsed `.vyx` component: its tag name, view-fn name, props, imports,
/// helpers, root node, whether it uses `<slot/>`, and any parse error.
type VyxComp = {
    name: String,
    fnName: String,
    fileId: String,
    srcPath: String,
    propNames: Array<String>,
    propTypes: Array<String>,
    imports: Array<String>,
    helpers: String,
    root: VyxNode,
    takesChildren: Bool,
    err: String,
}

/// Whether any node in `nodes` (transitively) is `<slot/>`.
fn vyxUsesChildren(nodes: Array<VyxNode>) -> Bool {
    for n in nodes {
        if vyxNodeUsesChildren(n) {
            return true
        }
    }
    return false
}

fn vyxNodeUsesChildren(n: VyxNode) -> Bool {
    return match n {
        VNChildren => true,
        VNElem(t, c, a, kids, l) => vyxUsesChildren(kids),
        VNIf(conds, cl, cc, bodies, els, has) => vyxIfUsesChildren(bodies, els, has),
        VNFor(v, it, k, body, l, c) => vyxUsesChildren(body),
        VNText(s) => false,
        VNInterp(x, l, c) => false,
        VNRaw(x, l, c) => false,
    }
}

fn vyxIfUsesChildren(bodies: Array<VyxBody>, els: VyxBody, has: Bool) -> Bool {
    for b in bodies {
        if vyxUsesChildren(b.nodes) {
            return true
        }
    }
    if has {
        return vyxUsesChildren(els.nodes)
    }
    return false
}

/// Compile one `.vyx` source into a `VyxComp` (parse only — component-call
/// resolution happens later, once every sibling name is known). `compName` is the
/// file stem; `dir` rebases relative imports. EXPORTED so `std/ui`'s `pages` can
/// reuse it for `.vyx` pages.
export fn vyxCompileComponent(compName: String, source: String, dir: String) -> VyxComp {
    let ba = bytes(source)
    let fileId = vyxIdentOf(compName + ".vyx")
    let fnName = vyxLowerFirst(compName)
    // The `.vyx` path relative to the generator's importing module — the base
    // RFC-0033 origin directives resolve against (identical to the `readFile`
    // path this component was read from).
    let srcPath = dir + "/" + compName + ".vyx"

    let scriptSec = vyxSection(ba, "script", true)
    // The template open tag skips the script section's range, so a literal
    // `<template>` inside a helper string never claims the section.
    let templateSec = vyxSectionAvoid(ba, "template", false, scriptSec.start, scriptSec.end)
    if templateSec.found == false {
        return vyxCompErr(compName, fnName, fileId, srcPath, vyxErr("VYX_NO_TEMPLATE", fileId, 0))
    }

    let mut propNames: Array<String> = []
    let mut propTypes: Array<String> = []
    let mut imports: Array<String> = []
    let mut helpers = ""
    if scriptSec.found {
        let bad = vyxImportsFirstViolation(ba, scriptSec.start, scriptSec.end, "props")
        if bad > 0 {
            return vyxCompErr(compName, fnName, fileId, srcPath, vyxErr("VYX_IMPORTS_FIRST", fileId, bad))
        }
        let sc = vyxParseScript(vyxSlice(ba, scriptSec.start, scriptSec.end), dir, fileId)
        if sc.err != "" {
            return vyxCompErr(compName, fnName, fileId, srcPath, sc.err)
        }
        propNames = sc.propNames
        propTypes = sc.propTypes
        imports = sc.imports
        helpers = sc.helpers
    }

    // Parse the template (over absolute file offsets, for true line numbers), then
    // group the flat sibling list into the control-flow AST.
    let parsed = vyxParseNodes(ba, templateSec.start, templateSec.end, fileId)
    if parsed.err != "" {
        return vyxCompErr(compName, fnName, fileId, srcPath, parsed.err)
    }
    let grouped = vyxGroupNodes(parsed.nodes, fileId)
    if grouped.err != "" {
        return vyxCompErr(compName, fnName, fileId, srcPath, grouped.err)
    }
    // Exactly one root element (whitespace-only text is already dropped).
    let roots = vyxElementRoots(grouped.nodes)
    if roots.length == 0 {
        return vyxCompErr(compName, fnName, fileId, srcPath, vyxErr("VYX_NO_ROOT", fileId, 0))
    }
    if roots.length > 1 {
        return vyxCompErr(compName, fnName, fileId, srcPath, vyxErr("VYX_MULTIPLE_ROOTS", fileId, vyxRootLine(roots)))
    }
    let root = roots[0]
    return VyxComp {
        name: compName,
        fnName: fnName,
        fileId: fileId,
        srcPath: srcPath,
        propNames: propNames,
        propTypes: propTypes,
        imports: imports,
        helpers: helpers,
        root: root,
        takesChildren: vyxUsesChildren([root]),
        err: "",
    }
}

/// The element/component roots among the top-level nodes (a bare interpolation or
/// control block at the root is not a valid single root).
fn vyxElementRoots(nodes: Array<VyxNode>) -> Array<VyxNode> {
    let mut out: Array<VyxNode> = []
    for n in nodes {
        let keep = match n {
            VNElem(t, c, a, k, l) => true,
            VNText(s) => false,
            VNInterp(x, l, c) => true,
            VNRaw(x, l, c) => true,
            VNChildren => true,
            VNIf(cc, cl, ccc, bb, ee, hh) => true,
            VNFor(v, it, kk, bd, l, c) => true,
        }
        if keep {
            out.push(n)
        }
    }
    return out
}

/// The line of the second root (for the multiple-roots diagnostic).
fn vyxRootLine(roots: Array<VyxNode>) -> Int64 {
    return match roots[1] {
        VNElem(t, c, a, k, l) => l,
        VNInterp(x, l, c) => l,
        VNRaw(x, l, c) => l,
        VNFor(v, it, kk, bd, l, c) => l,
        VNChildren => 0,
        VNText(s) => 0,
        VNIf(cc, cl, ccc, bb, ee, hh) => 0,
    }
}

/// A `VyxComp` carrying only an error.
fn vyxCompErr(name: String, fnName: String, fileId: String, srcPath: String, err: String) -> VyxComp {
    return VyxComp {
        name: name,
        fnName: fnName,
        fileId: fileId,
        srcPath: srcPath,
        propNames: [],
        propTypes: [],
        imports: [],
        helpers: "",
        root: VNText(""),
        takesChildren: false,
        err: err,
    }
}

// ===========================================================================
// RFC-0033 origin directives — the format-agnostic breadcrumbs the toolchain
// remaps diagnostics and editor requests through. A directive attributes the
// generated lines that FOLLOW it to a `.vyx` position, until the next directive
// or `//@origin end`. It is an ordinary `//` comment: inert for parsing, gen
// cache hashing, `fmt`, and `emit-gen`.
// ===========================================================================

/// A `//@origin <path>:<line>:<col>` directive line (RFC-0033).
fn vyxOrigin(src: String, line: Int64, col: Int64) -> String {
    return "//@origin " + src + ":" + line.toString() + ":" + col.toString() + "\n"
}

/// A `//@origin end` line — following generated lines are attributed to the
/// synthesized module itself (a derived region), not the last input position.
fn vyxOriginEnd() -> String {
    return "//@origin end\n"
}

// ===========================================================================
// Code generation — a post-order walk emitting `std/html` hyperscript. Every
// element builds a `mut Array<Html>` accumulator (named by its unique tree path),
// so `v-if` / `v-for` / `<slot/>` all lower to ordinary imperative pushes. Each
// verbatim pass-through (`{{ expr }}`, `v-if` condition, `v-for` head, `:attr`
// value, `@event` arg) is wrapped in an `//@origin` directive with the exact
// `.vyx` column (RFC-0039 §1 origin-fidelity upgrade).
// ===========================================================================

/// The registry of sibling components, for resolving `<Capitalized>` tags.
/// `themed` (RFC-0036) routes every `class` attribute through `vyxTheme.cls(…)`
/// (compile-checked for a static literal, runtime-validated for a dynamic expr)
/// instead of a bare `Cls(…)`.
type VyxRegistry = { names: Array<String>, comps: Array<VyxComp>, themed: Bool }

fn vyxLookup(reg: VyxRegistry, name: String) -> Int64 {
    let mut i = 0
    while i < reg.names.length {
        if reg.names[i] == name {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

/// Emit the statements pushing every node in `nodes` into accumulator `acc`,
/// under tree-path `path`. Accumulates component-resolution errors into `errs`
/// (returned via the result).
type VyxEmit = { code: String, err: String }

fn vyxEmitChildren(nodes: Array<VyxNode>, acc: String, path: String, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    let mut code = ""
    let mut err = ""
    let mut j = 0
    for n in nodes {
        let r = vyxEmitPush(n, acc, path + "_" + j.toString(), reg, fileId, src)
        code = code + r.code
        err = err + r.err
        j = j + 1
    }
    return VyxEmit { code: code, err: err }
}

/// Emit the statements that push one node into `acc`.
fn vyxEmitPush(n: VyxNode, acc: String, path: String, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    return match n {
        VNText(s) => VyxEmit { code: acc + ".push(text(" + vyxStrLit(s) + "))\n", err: "" },
        VNInterp(x, l, c) => VyxEmit { code: vyxOrigin(src, l, c) + acc + ".push(text((" + x + ").toString()))\n" + vyxOriginEnd(), err: "" },
        VNRaw(x, l, c) => VyxEmit { code: vyxOrigin(src, l, c) + acc + ".push(Raw(" + x + "))\n" + vyxOriginEnd(), err: "" },
        VNChildren => VyxEmit { code: "for vyxCh in children {\n" + acc + ".push(vyxCh)\n}\n", err: "" },
        VNElem(tag, isComp, attrs, kids, l) => vyxEmitElem(tag, isComp, attrs, kids, l, acc, path, reg, fileId, src),
        VNIf(conds, cl, cc, bodies, els, has) => vyxEmitIf(conds, cl, cc, bodies, els, has, acc, path, reg, fileId, src),
        VNFor(v, it, k, body, l, c) => vyxEmitFor(v, it, k, body, l, c, acc, path, reg, fileId, src),
    }
}

/// Emit an element (or dispatch to a component call).
fn vyxEmitElem(tag: String, isComp: Bool, attrs: Array<VyxAttr>, kids: Array<VyxNode>, line: Int64, acc: String, path: String, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    if isComp {
        return vyxEmitComp(tag, attrs, kids, line, acc, path, reg, fileId, src)
    }
    let kacc = "k" + path
    let kids2 = vyxEmitChildren(kids, kacc, path, reg, fileId, src)
    // Attributes (incl. `@event` and dyn `:attr` values) are hoisted onto their
    // own `//@origin`-governed `let` bindings (`ae.pre`) so a type error maps
    // column-exactly onto the expression in the `.vyx`; the attribute slot then
    // references that binding. Static attributes stay inline (`ae.list`).
    let ae = vyxEmitAttrs(attrs, reg, fileId, src, kacc)
    let code = "let mut " + kacc + ": Array<Html> = []\n" + kids2.code + ae.pre + acc + ".push(el(" + vyxStrLit(tag) + ", [" + ae.list + "], " + kacc + "))\n"
    return VyxEmit { code: code, err: kids2.err + ae.err }
}

/// Emit a component call, resolving props by name against the component's
/// declaration and passing `<slot/>` content when it accepts children.
fn vyxEmitComp(tag: String, attrs: Array<VyxAttr>, kids: Array<VyxNode>, line: Int64, acc: String, path: String, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    let idx = vyxLookup(reg, tag)
    if idx < 0 {
        return VyxEmit { code: acc + ".push(empty())\n", err: vyxErrDetail("VYX_UNKNOWN_COMPONENT", fileId, line, tag) }
    }
    let comp = reg.comps[idx]
    let mut err = ""
    // Each declared prop, in order, mapped to the tag's attribute value.
    let mut args: Array<String> = []
    let mut pi = 0
    while pi < comp.propNames.length {
        let pn = comp.propNames[pi]
        let av = vyxFindAttr(attrs, pn)
        if av.found == false {
            err = err + vyxErrDetail("VYX_MISSING_PROP", fileId, line, tag + "_" + pn)
            args.push("empty()")
        } else if av.dyn {
            args.push(av.value)
        } else {
            args.push(vyxStrLit(av.value))
        }
        pi = pi + 1
    }
    // Reject unknown / event attributes on a component.
    for a in attrs {
        if a.evt {
            err = err + vyxErrDetail("VYX_EVENT_ON_COMPONENT", fileId, a.line, tag + "_" + a.name)
        } else if vyxContains(comp.propNames, a.name) == false {
            err = err + vyxErrDetail("VYX_UNKNOWN_PROP", fileId, a.line, tag + "_" + a.name)
        }
    }
    let hasKids = vyxTrim(vyxChildText(kids)).length > 0 || kids.length > 0
    if comp.takesChildren {
        let kacc = "k" + path
        let kids2 = vyxEmitChildren(kids, kacc, path, reg, fileId, src)
        let code = "let mut " + kacc + ": Array<Html> = []\n" + kids2.code + acc + ".push(" + comp.fnName + "(" + vyxJoinArgs(args) + kacc + "))\n"
        return VyxEmit { code: code, err: err + kids2.err }
    }
    if hasKids {
        err = err + vyxErrDetail("VYX_UNEXPECTED_CHILDREN", fileId, line, tag)
    }
    return VyxEmit { code: acc + ".push(" + comp.fnName + "(" + vyxJoinArgsClose(args) + "))\n", err: err }
}

/// The argument prefix `a, b, ` (trailing separator) for a call that appends a
/// children accumulator; "" for no args.
fn vyxJoinArgs(args: Array<String>) -> String {
    let mut out = ""
    for a in args {
        out = out + a + ", "
    }
    return out
}

/// The complete argument list `a, b` for a childless call.
fn vyxJoinArgsClose(args: Array<String>) -> String {
    return vyxJoin(args, ", ")
}

/// Whether the paired children hold any non-whitespace content (text only — a
/// coarse signal used to reject children on a childless component).
fn vyxChildText(kids: Array<VyxNode>) -> String {
    let mut out = ""
    for n in kids {
        out = out + match n {
            VNText(s) => s,
            VNInterp(x, l, c) => "x",
            VNRaw(x, l, c) => "x",
            VNChildren => "c",
            VNElem(t, c, a, k, l) => "e",
            VNIf(cc, cl, ccc, bb, ee, hh) => "i",
            VNFor(v, it, kk, bd, l, c) => "f",
        }
    }
    return out
}

/// A found attribute value.
type VyxAttrFound = { found: Bool, value: String, dyn: Bool }

fn vyxFindAttr(attrs: Array<VyxAttr>, name: String) -> VyxAttrFound {
    for a in attrs {
        if a.evt == false && a.name == name {
            return VyxAttrFound { found: true, value: a.value, dyn: a.dyn }
        }
    }
    return VyxAttrFound { found: false, value: "", dyn: false }
}

/// Emit a `v-if` chain: each branch fills its own accumulator, then splices it
/// into `acc`; a missing `v-else` elides to Empty (nothing pushed). Each condition
/// is verbatim on the `if …` line its OWN `//@origin` directive governs, so a
/// type error in any `v-if`/`v-else-if` condition maps to that condition's column.
fn vyxEmitIf(conds: Array<String>, condLines: Array<Int64>, condCols: Array<Int64>, bodies: Array<VyxBody>, els: VyxBody, has: Bool, acc: String, path: String, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    let mut code = ""
    let mut err = ""
    let mut bi = 0
    while bi < conds.length {
        let head = if bi > 0 { "} else if " } else { "if " }
        let bacc = "k" + path + "_b" + bi.toString()
        let inner = vyxEmitChildren(bodies[bi].nodes, bacc, path + "_b" + bi.toString(), reg, fileId, src)
        err = err + inner.err
        code = code + vyxOrigin(src, condLines[bi], condCols[bi]) + head + conds[bi] + " {\n" + vyxOriginEnd()
        code = code + "let mut " + bacc + ": Array<Html> = []\n" + inner.code
        code = code + "for vyxN in " + bacc + " {\n" + acc + ".push(vyxN)\n}\n"
        bi = bi + 1
    }
    if has {
        let eacc = "k" + path + "_be"
        let inner = vyxEmitChildren(els.nodes, eacc, path + "_be", reg, fileId, src)
        err = err + inner.err
        code = code + "} else {\n"
        code = code + "let mut " + eacc + ": Array<Html> = []\n" + inner.code
        code = code + "for vyxN in " + eacc + " {\n" + acc + ".push(vyxN)\n}\n"
    }
    code = code + "}\n"
    return VyxEmit { code: code, err: err }
}

/// Emit a `v-for` loop: each iteration fills a fresh accumulator, then splices it
/// into `acc` with a `Key` (the key expression rendered to a String).
fn vyxEmitFor(v: String, it: String, key: String, body: Array<VyxNode>, line: Int64, col: Int64, acc: String, path: String, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    let facc = "k" + path + "_f"
    let inner = vyxEmitChildren(body, facc, path + "_f", reg, fileId, src)
    // The `v-for` head (loop var + iterable) is verbatim on the `for …` line; the
    // directive points at the header column.
    let mut code = vyxOrigin(src, line, col)
    code = code + "for " + v + " in " + it + " {\n" + vyxOriginEnd()
    code = code + "let mut " + facc + ": Array<Html> = []\n" + inner.code
    code = code + "for vyxN in " + facc + " {\n" + acc + ".push(keyed((" + key + ").toString(), vyxN))\n}\n"
    code = code + "}\n"
    return VyxEmit { code: code, err: inner.err }
}

// ---- attributes -------------------------------------------------------------

/// The attribute list plus the preamble statements that must precede the element's
/// push line. Every expression-bearing attribute — a dynamic `:attr` value, a
/// `@event` binding (its scalar arg), and a themed static/dynamic `class` — is
/// hoisted into its own `//@origin`-governed `let` binding (`pre`) so a type
/// error lands column-exactly on the expression in the `.vyx`; the attribute slot
/// then references that binding. Static attributes stay inline (`list`).
type VyxAttrsEmit = { list: String, pre: String, err: String }

/// Emit the comma-joined `Attr` constructors for a tag's attributes. `class` →
/// `Cls` (or `vyxTheme.cls` when `reg.themed`); `@event` → `On`; everything else
/// → `A(name, value)`. `clsBase` names the hoisted bindings uniquely.
fn vyxEmitAttrs(attrs: Array<VyxAttr>, reg: VyxRegistry, fileId: String, src: String, clsBase: String) -> VyxAttrsEmit {
    let mut parts: Array<String> = []
    let mut pre = ""
    let mut err = ""
    let mut ai = 0
    for a in attrs {
        let slot = clsBase + "_a" + ai.toString()
        if a.evt {
            let ev = vyxEmitEvent(a, fileId)
            err = err + ev.err
            if ev.hasArg {
                // Hoist the event onto its own origin-governed line so a bad
                // scalar-arg expression maps to the arg's exact column.
                pre = pre + vyxOrigin(src, ev.argLine, ev.argCol)
                pre = pre + "let " + slot + ": Attr = " + ev.code + "\n"
                pre = pre + vyxOriginEnd()
                parts.push(slot)
            } else {
                parts.push(ev.code)
            }
        } else if a.name == "class" {
            if reg.themed {
                // Themed class: a static literal is proven `⊆ Tw` at compile time,
                // a dynamic expr coerces at runtime — both hoisted so the check
                // maps to the class string's exact column.
                let cv = if a.dyn { a.value } else { vyxStrLit(a.value) }
                pre = pre + vyxOrigin(src, a.line, a.col)
                pre = pre + "let " + slot + ": Attr = vyxTheme.cls(" + cv + ")\n"
                pre = pre + vyxOriginEnd()
                parts.push(slot)
            } else {
                let cv = if a.dyn { a.value } else { vyxStrLit(a.value) }
                if a.dyn {
                    pre = pre + vyxOrigin(src, a.line, a.col)
                    pre = pre + "let " + slot + ": Attr = Cls(" + cv + ")\n"
                    pre = pre + vyxOriginEnd()
                    parts.push(slot)
                } else {
                    parts.push("Cls(" + cv + ")")
                }
            }
        } else if a.dyn {
            // A dynamic `:attr` value hoisted under a column-exact origin.
            pre = pre + vyxOrigin(src, a.line, a.col)
            pre = pre + "let " + slot + ": Attr = A(" + vyxStrLit(a.name) + ", " + a.value + ")\n"
            pre = pre + vyxOriginEnd()
            parts.push(slot)
        } else {
            parts.push("A(" + vyxStrLit(a.name) + ", " + vyxStrLit(a.value) + ")")
        }
        ai = ai + 1
    }
    return VyxAttrsEmit { list: vyxJoin(parts, ", "), pre: pre, err: err }
}

/// One emitted `@event` binding, with the column of its scalar-arg expression (for
/// the hoisting origin) when it has one.
type VyxEventEmit = { code: String, err: String, hasArg: Bool, argLine: Int64, argCol: Int64 }

/// Emit one `@event="handler(scalar)"` binding as `On(event, "handler",
/// payload)`. Exactly one handler name plus at most one scalar argument (the v1
/// restriction — module state is root-only, handlers are root-exported externs).
fn vyxEmitEvent(a: VyxAttr, fileId: String) -> VyxEventEmit {
    let spec = vyxTrim(a.value)
    let sb = bytes(spec)
    // Split the handler name from an optional `(arg)`.
    let paren = vyxFind(sb, bytes("("), 0)
    if paren < 0 {
        if vyxIsIdentifier(spec) == false {
            return VyxEventEmit { code: "On(" + vyxStrLit(a.name) + ", \"\", \"\")", err: vyxErrDetail("VYX_BAD_EVENT_HANDLER", fileId, a.line, a.name), hasArg: false, argLine: a.line, argCol: a.col }
        }
        return VyxEventEmit { code: "On(" + vyxStrLit(a.name) + ", " + vyxStrLit(spec) + ", \"\")", err: "", hasArg: false, argLine: a.line, argCol: a.col }
    }
    let handler = vyxTrim(vyxSlice(sb, 0, paren))
    if vyxIsIdentifier(handler) == false {
        return VyxEventEmit { code: "On(" + vyxStrLit(a.name) + ", \"\", \"\")", err: vyxErrDetail("VYX_BAD_EVENT_HANDLER", fileId, a.line, a.name), hasArg: false, argLine: a.line, argCol: a.col }
    }
    let closeParen = vyxFindLast(sb, bytes(")"), paren)
    let argExpr = vyxTrim(vyxSlice(sb, paren + 1, closeParen))
    if argExpr.length == 0 {
        return VyxEventEmit { code: "On(" + vyxStrLit(a.name) + ", " + vyxStrLit(handler) + ", \"\")", err: "", hasArg: false, argLine: a.line, argCol: a.col }
    }
    // At most one scalar argument: a top-level comma means more than one.
    if vyxHasTopComma(bytes(argExpr)) {
        return VyxEventEmit { code: "On(" + vyxStrLit(a.name) + ", " + vyxStrLit(handler) + ", \"\")", err: vyxErrDetail("VYX_NON_SCALAR_EVENT_ARG", fileId, a.line, a.name), hasArg: false, argLine: a.line, argCol: a.col }
    }
    // The arg's column = the value's start column + the byte offset of the first
    // non-whitespace byte past `(` (attribute values are single-line).
    let argRel = vyxSkipWs(sb, paren + 1, sb.length)
    let argCol = a.col + argRel
    return VyxEventEmit { code: "On(" + vyxStrLit(a.name) + ", " + vyxStrLit(handler) + ", (" + argExpr + ").toString())", err: "", hasArg: true, argLine: a.line, argCol: argCol }
}

/// Whether `s` is a single Vyrn identifier (letters/digits/_; not digit-first).
fn vyxIsIdentifier(s: String) -> Bool {
    let ba = bytes(s)
    if ba.length == 0 {
        return false
    }
    if ba[0] >= 48 && ba[0] <= 57 {
        return false
    }
    for b in ba {
        if vyxIsIdent(b) == false {
            return false
        }
    }
    return true
}

/// Whether `ba` has a comma at paren/generic/bracket depth 0 (more than one arg).
fn vyxHasTopComma(ba: Array<UInt8>) -> Bool {
    let mut depth = 0
    let mut i = 0
    while i < ba.length {
        let b = ba[i]
        if b == 40 || b == 91 || b == 60 {
            depth = depth + 1
        } else if b == 41 || b == 93 || b == 62 {
            depth = depth - 1
        } else if b == 34 {
            i = vyxScanQuote(ba, i, ba.length) - 1
        } else if b == 44 && depth == 0 {
            return true
        }
        i = i + 1
    }
    return false
}

// ===========================================================================
// Import dedup (RFC-0039 §3) — the synthesized module merges the import lines of
// all component scripts: identical selective imports collapse and same-spec
// selective imports union their name sets; `import * as ns` dedups by (ns, spec);
// a CONFLICT (the same imported name from two different specs across two
// components) is a generation diagnostic naming both files. This lets a component
// script import what it needs directly (i18n instances, wire types) without the
// scalar-threading v1 forced.
// ===========================================================================

/// One parsed import line.
type VyxImport = { ns: Bool, ok: Bool, names: Array<String>, alias: String, spec: String }

/// Parse `import { A, B } from <spec>` or `import * as ns from <spec>`. `spec` is
/// everything after ` from ` (a `"…"` literal or a `gen("…")` call), used as the
/// dedup/conflict key. `ok=false` for an unrecognized shape (passed through raw).
fn vyxParseImport(line: String) -> VyxImport {
    let ba = bytes(line)
    let fromAt = vyxFind(ba, bytes(" from "), 0)
    if fromAt < 0 {
        return VyxImport { ns: false, ok: false, names: [], alias: "", spec: "" }
    }
    let spec = vyxTrim(vyxSlice(ba, fromAt + 6, ba.length))
    let head = vyxTrim(vyxSlice(ba, 0, fromAt))
    if head.startsWith("import * as ") {
        let alias = vyxTrim(vyxSlice(bytes(head), 12, bytes(head).length))
        return VyxImport { ns: true, ok: true, names: [], alias: alias, spec: spec }
    }
    let braceOpen = vyxFind(bytes(head), bytes("{"), 0)
    let braceClose = vyxFindLast(bytes(head), bytes("}"), 0)
    if braceOpen < 0 || braceClose <= braceOpen {
        return VyxImport { ns: false, ok: false, names: [], alias: "", spec: spec }
    }
    let inner = vyxSlice(bytes(head), braceOpen + 1, braceClose)
    let mut names: Array<String> = []
    for part in vyxSplitFields(inner) {
        let t = vyxTrim(part)
        if t.length > 0 {
            names.push(t)
        }
    }
    return VyxImport { ns: false, ok: true, names: names, alias: "", spec: spec }
}

/// The merged import block plus any conflict diagnostic. `fileIds` parallels
/// `comps` for naming both sides of a conflict.
type VyxMerge = { block: String, err: String }

fn vyxMergeImports(comps: Array<VyxComp>) -> VyxMerge {
    // Selective imports: first-seen spec order, unioned names; track each name's
    // (spec, file) to detect a same-name/different-spec conflict.
    let mut selSpecs: Array<String> = []
    let mut selNames: Array<Array<String>> = []
    // Namespace imports deduped by (alias, spec).
    let mut nsAlias: Array<String> = []
    let mut nsSpec: Array<String> = []
    // Raw pass-through lines (unrecognized shapes), deduped exactly.
    let mut rawLines: Array<String> = []
    // Conflict tracking: name → spec/file first seen.
    let mut cName: Array<String> = []
    let mut cSpec: Array<String> = []
    let mut cFile: Array<String> = []
    let mut err = ""

    for c in comps {
        for line in c.imports {
            let imp = vyxParseImport(line)
            if imp.ok == false {
                if vyxContains(rawLines, line) == false {
                    rawLines.push(line)
                }
            } else if imp.ns {
                // Dedup by (alias, spec); an alias reused for a different spec is a
                // conflict.
                let mut found = false
                let mut k = 0
                while k < nsAlias.length {
                    if nsAlias[k] == imp.alias {
                        found = true
                        if nsSpec[k] != imp.spec {
                            err = err + "VYX_IMPORT_CONFLICT__" + vyxIdentOf(imp.alias) + "__in__" + c.fileId + "\n"
                        }
                    }
                    k = k + 1
                }
                if found == false {
                    nsAlias.push(imp.alias)
                    nsSpec.push(imp.spec)
                }
            } else {
                // Selective: union into the spec's name set; check each name for a
                // conflicting spec.
                for nm in imp.names {
                    let mut seen = false
                    let mut ci = 0
                    while ci < cName.length {
                        if cName[ci] == nm {
                            seen = true
                            if cSpec[ci] != imp.spec {
                                err = err + "VYX_IMPORT_CONFLICT__" + vyxIdentOf(nm) + "__" + cFile[ci] + "__and__" + c.fileId + "\n"
                            }
                        }
                        ci = ci + 1
                    }
                    if seen == false {
                        cName.push(nm)
                        cSpec.push(imp.spec)
                        cFile.push(c.fileId)
                    }
                }
                // Union into the spec bucket.
                let mut si = 0 - 1
                let mut k = 0
                while k < selSpecs.length {
                    if selSpecs[k] == imp.spec {
                        si = k
                    }
                    k = k + 1
                }
                if si < 0 {
                    selSpecs.push(imp.spec)
                    selNames.push(imp.names)
                } else {
                    let mut cur = selNames[si]
                    for nm in imp.names {
                        if vyxContains(cur, nm) == false {
                            cur.push(nm)
                        }
                    }
                    selNames[si] = cur
                }
            }
        }
    }

    let mut out = ""
    let mut i = 0
    while i < selSpecs.length {
        out = out + "import { " + vyxJoin(selNames[i], ", ") + " } from " + selSpecs[i] + "\n"
        i = i + 1
    }
    i = 0
    while i < nsAlias.length {
        out = out + "import * as " + nsAlias[i] + " from " + nsSpec[i] + "\n"
        i = i + 1
    }
    for line in rawLines {
        out = out + line + "\n"
    }
    return VyxMerge { block: out, err: err }
}

// ===========================================================================
// Assembling the synthesized module.
// ===========================================================================

/// The view-function signature for a component: `fn name(p: T, …, children:
/// Array<Html>) -> Html` (the children param only when the template uses `<slot/>`).
fn vyxEmitSignature(comp: VyxComp) -> String {
    let mut params: Array<String> = []
    let mut i = 0
    while i < comp.propNames.length {
        params.push(comp.propNames[i] + ": " + comp.propTypes[i])
        i = i + 1
    }
    if comp.takesChildren {
        params.push("children: Array<Html>")
    }
    return "export fn " + comp.fnName + "(" + vyxJoin(params, ", ") + ") -> Html {\n"
}

/// Emit one component's view function. The single root is returned directly (its
/// children built into a fresh accumulator first).
fn vyxEmitComponent(comp: VyxComp, reg: VyxRegistry) -> VyxEmit {
    let mut out = vyxEmitSignature(comp)
    let rootEmit = vyxEmitRoot(comp.root, reg, comp.fileId, comp.srcPath)
    out = out + rootEmit.code + "}\n"
    return VyxEmit { code: out, err: rootEmit.err }
}

/// Emit the root node as `let …; return <expr>` (the view fn returns one `Html`).
fn vyxEmitRoot(root: VyxNode, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    return match root {
        VNElem(tag, isComp, attrs, kids, l) => vyxEmitRootElem(tag, isComp, attrs, kids, l, reg, fileId, src),
        VNText(s) => VyxEmit { code: "return text(" + vyxStrLit(s) + ")\n", err: "" },
        VNInterp(x, l, c) => VyxEmit { code: vyxOrigin(src, l, c) + "return text((" + x + ").toString())\n" + vyxOriginEnd(), err: "" },
        VNRaw(x, l, c) => VyxEmit { code: vyxOrigin(src, l, c) + "return Raw(" + x + ")\n" + vyxOriginEnd(), err: "" },
        VNChildren => VyxEmit { code: "let mut kr: Array<Html> = []\nfor vyxCh in children {\nkr.push(vyxCh)\n}\nreturn el(\"div\", [], kr)\n", err: "" },
        VNIf(cc, cl, ccc, bb, ee, hh) => vyxEmitRootWrap(root, reg, fileId, src),
        VNFor(v, it, k, bd, l, c) => vyxEmitRootWrap(root, reg, fileId, src),
    }
}

/// A root element/component returned directly.
fn vyxEmitRootElem(tag: String, isComp: Bool, attrs: Array<VyxAttr>, kids: Array<VyxNode>, line: Int64, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    if isComp {
        let pushed = vyxEmitComp(tag, attrs, kids, line, "kr", "r", reg, fileId, src)
        let code = "let mut kr: Array<Html> = []\n" + pushed.code + "return kr[0]\n"
        return VyxEmit { code: code, err: pushed.err }
    }
    let kids2 = vyxEmitChildren(kids, "kr", "r", reg, fileId, src)
    let ae = vyxEmitAttrs(attrs, reg, fileId, src, "kr")
    let code = "let mut kr: Array<Html> = []\n" + kids2.code + ae.pre + "return el(" + vyxStrLit(tag) + ", [" + ae.list + "], kr)\n"
    return VyxEmit { code: code, err: kids2.err + ae.err }
}

/// A root that is a bare `v-if` / `v-for` — pushed into a `<div>` wrapper (kept
/// simple; the common root is a real element).
fn vyxEmitRootWrap(root: VyxNode, reg: VyxRegistry, fileId: String, src: String) -> VyxEmit {
    let pushed = vyxEmitPush(root, "kr", "r", reg, fileId, src)
    let code = "let mut kr: Array<Html> = []\n" + pushed.code + "return el(\"div\", [], kr)\n"
    return VyxEmit { code: code, err: pushed.err }
}

/// Assemble the whole synthesized module from the compiled components. When
/// `themed` (RFC-0036), the module imports the theme namespaced and every `class`
/// attribute is routed through `vyxTheme.cls(…)`; `theme` is the path passed to
/// `componentsThemed`, resolved (like `dir`) relative to the importing module.
/// EXPORTED so `std/ui`'s `pages` can build a page module from `.vyx` components.
export fn vyxBuildModule(comps: Array<VyxComp>, themed: Bool, theme: String) -> String {
    let reg = VyxRegistry { names: vyxCompNames(comps), comps: comps, themed: themed }
    let mut out = "/// Generated by std/vyx `components` (RFC-0026 M4, RFC-0039 v2) — do not edit.\n"
    out = out + "import { el, text, keyed, empty, Html, Attr } from \"std/html\"\n"
    if themed {
        out = out + "import { tw } from \"std/tw\"\n"
        out = out + "import * as vyxTheme from tw(" + vyxStrLit(theme) + ")\n"
    }

    // Merged pass-through imports from every component (RFC-0039 §3).
    let merged = vyxMergeImports(comps)
    if merged.err != "" {
        return merged.err
    }
    out = out + merged.block

    // Pass-through helpers (module-internal, flat namespace across components).
    for c in comps {
        if vyxTrim(c.helpers).length > 0 {
            out = out + c.helpers
        }
    }
    // One view function per component.
    let mut err = ""
    for c in comps {
        let e = vyxEmitComponent(c, reg)
        out = out + e.code
        err = err + e.err
    }
    if err != "" {
        return err
    }
    return out
}

/// The tag names of all compiled components.
fn vyxCompNames(comps: Array<VyxComp>) -> Array<String> {
    let mut out: Array<String> = []
    for c in comps {
        out.push(c.name)
    }
    return out
}

// ===========================================================================
// The generator.
// ===========================================================================

/// Assemble the synthesized module from the compiled components, or return the
/// accumulated generation diagnostics. The PURE tail shared by `components` /
/// `componentsThemed` — the `listDir` / `readFile` I/O stays in the `gen fn`
/// bodies (a comptime-only builtin has no native/wasm lowering, so it may only
/// appear directly in a generator body), and this is called with the results.
fn vyxFinish(comps: Array<VyxComp>, err: String, themed: Bool, theme: String) -> String {
    if comps.length == 0 {
        return "VYX_ERROR__no_vyx_files_found_under_the_components_directory\n"
    }
    if err != "" {
        return err
    }
    return vyxBuildModule(comps, themed, theme)
}

/// `components(dir)` — compile every `<Name>.vyx` file under `dir` into ONE module
/// exporting one view function per component. `class="…"` emits an unchecked
/// `Cls(…)` (backward-compatible, unchanged). Reach for `componentsThemed` to
/// compile-check classes against a theme.
export gen fn components(dir: String) -> String {
    let entries = match listDir(dir) {
        Ok(ns) => ns,
        Err(err) => [],
    }
    let mut comps: Array<VyxComp> = []
    let mut err = ""
    for name in entries {
        if name.endsWith(".vyx") {
            let nb = bytes(name)
            let stem = vyxSlice(nb, 0, nb.length - 4)
            let src = match readFile(dir + "/" + name) {
                Ok(v) => v,
                Err(e) => "",
            }
            let comp = vyxCompileComponent(stem, src, dir)
            if comp.err != "" {
                err = err + comp.err
            }
            comps.push(comp)
        }
    }
    return vyxFinish(comps, err, false, "")
}

/// `componentsThemed(dir, theme)` (RFC-0036) — like `components`, but the
/// synthesized module imports `theme` namespaced (`import * as vyxTheme from
/// tw(<theme>)`) and routes every `class` attribute through `vyxTheme.cls(…)`: a
/// STATIC class literal is proven `⊆ Tw` at compile time (a typo is a `vyrn check`
/// error mapped to the `.vyx` line:col), a dynamic `:class="expr"` is coerced to
/// `Tw` at runtime. `theme` resolves relative to the importing module, exactly
/// like `dir`.
export gen fn componentsThemed(dir: String, theme: String) -> String {
    let entries = match listDir(dir) {
        Ok(ns) => ns,
        Err(err) => [],
    }
    let mut comps: Array<VyxComp> = []
    let mut err = ""
    for name in entries {
        if name.endsWith(".vyx") {
            let nb = bytes(name)
            let stem = vyxSlice(nb, 0, nb.length - 4)
            let src = match readFile(dir + "/" + name) {
                Ok(v) => v,
                Err(e) => "",
            }
            let comp = vyxCompileComponent(stem, src, dir)
            if comp.err != "" {
                err = err + comp.err
            }
            comps.push(comp)
        }
    }
    return vyxFinish(comps, err, true, theme)
}

// ===========================================================================
// `.vyx` pages (RFC-0039 §4) — a `.vyx` PAGE has a `<script>` with a `params { … }`
// block (bracket-segment binding, the page analogue of `props`), plain helper fns,
// imports, and optionally `fn load(<params>) -> Validation<Data>` (+ `type Data`);
// its `<template>` is the page body. `std/ui`'s `pages` reads the file itself
// (comptime builtins in its gen body) and calls the pure `vyxBuildPageModule`
// core here, which synthesizes a page module exporting `page`/`Params`/`load`/
// `Data` — exactly the shape the router already consumes. `load` and `Data` are
// auto-exported so the router reaches them through the page's namespace.
// ===========================================================================

/// The shape `std/ui` needs to route a `.vyx` page: its `params` fields (parallel
/// name/type arrays), whether it declares a loader, the loader's return-type
/// spelling (`loadRet` — `Validation<…>` or `Result<…>`, RFC-0041 §3), and whether
/// it opts out of the layout with `layout="none"` (RFC-0041 §1). `err` names a
/// params fault.
type VyxPageShape = { paramNames: Array<String>, paramTypes: Array<String>, hasLoad: Bool, loadRet: String, layoutNone: Bool, err: String }

/// Whether the script text declares a statement-leading `fn load` (or
/// `export fn load`) — the page's optional loader.
fn vyxScriptHasLoad(script: String) -> Bool {
    for line in vyxLines(script) {
        let t = vyxTrim(line)
        if t.startsWith("fn load") || t.startsWith("export fn load") {
            return true
        }
    }
    return false
}

/// The loader's declared return-type spelling — the text between `->` and the
/// opening `{` of the `fn load(…)` line (RFC-0041 §3: `Validation<Data>` vs
/// `Result<Data, PageError>`). "" when there is no loader.
fn vyxScriptLoadRet(script: String) -> String {
    for line in vyxLines(script) {
        let t = vyxTrim(line)
        if t.startsWith("fn load") || t.startsWith("export fn load") {
            let tb = bytes(t)
            let arrow = vyxFind(tb, bytes("->"), 0)
            if arrow < 0 {
                return ""
            }
            let brace = vyxFind(tb, bytes("{"), arrow)
            let end = if brace < 0 { tb.length } else { brace }
            return vyxTrim(vyxSlice(tb, arrow + 2, end))
        }
    }
    return ""
}

/// Whether the page opts out of the layout with a statement-leading
/// `layout="none"` directive in its `<script>` (RFC-0041 §1). Spaces around the
/// `=` are tolerated; the value must be the string `none`.
fn vyxScriptLayoutNone(script: String) -> Bool {
    for line in vyxLines(script) {
        let t = vyxTrim(line)
        if t.startsWith("layout") {
            let rest = vyxTrim(vyxSlice(bytes(t), 6, bytes(t).length))
            if rest.startsWith("=") {
                let val = vyxTrim(vyxSlice(bytes(rest), 1, bytes(rest).length))
                if val == "\"none\"" || val == "'none'" || val == "none" {
                    return true
                }
            }
        }
    }
    return false
}

/// Whether a script line is the `layout="none"` directive (dropped from the
/// pass-through script — it is not valid Vyrn).
fn vyxIsLayoutLine(line: String) -> Bool {
    let t = vyxTrim(line)
    if t.startsWith("layout") == false {
        return false
    }
    let rest = vyxTrim(vyxSlice(bytes(t), 6, bytes(t).length))
    return rest.startsWith("=")
}

/// Reflect a `.vyx` page's `<script>` — its `params` fields and loader presence.
/// EXPORTED so `std/ui` learns the page's routing shape without duplicating the
/// scanner. (`err` is set on a malformed `params` block.)
export fn vyxPageShape(source: String) -> VyxPageShape {
    let ba = bytes(source)
    let scriptSec = vyxSection(ba, "script", true)
    if scriptSec.found == false {
        return VyxPageShape { paramNames: [], paramTypes: [], hasLoad: false, loadRet: "", layoutNone: false, err: "" }
    }
    let bad = vyxImportsFirstViolation(ba, scriptSec.start, scriptSec.end, "params")
    if bad > 0 {
        return VyxPageShape { paramNames: [], paramTypes: [], hasLoad: false, loadRet: "", layoutNone: false, err: vyxErr("VYX_IMPORTS_FIRST", "vyx_page", bad) }
    }
    let script = vyxSlice(ba, scriptSec.start, scriptSec.end)
    let sb = bytes(script)
    let loadRet = vyxScriptLoadRet(script)
    let layoutNone = vyxScriptLayoutNone(script)
    let pb = vyxFindKwBlock(sb, "params")
    let mut names: Array<String> = []
    let mut types: Array<String> = []
    if pb.found {
        if pb.malformed {
            return VyxPageShape { paramNames: [], paramTypes: [], hasLoad: false, loadRet: "", layoutNone: false, err: "VYX_BAD_PARAMS\n" }
        }
        let end = vyxMatchCurly(sb, pb.braceAt)
        for part in vyxSplitFields(vyxSlice(sb, pb.braceAt + 1, end - 1)) {
            let trimmed = vyxTrim(part)
            if trimmed.length > 0 {
                let pbf = bytes(trimmed)
                let mut colon = 0 - 1
                let mut k = 0
                while k < pbf.length && colon < 0 {
                    if pbf[k] == 58 {
                        colon = k
                    }
                    k = k + 1
                }
                if colon < 0 {
                    return VyxPageShape { paramNames: [], paramTypes: [], hasLoad: false, loadRet: "", layoutNone: false, err: "VYX_BAD_PARAMS\n" }
                }
                names.push(vyxTrim(vyxSlice(pbf, 0, colon)))
                types.push(vyxTrim(vyxSlice(pbf, colon + 1, pbf.length)))
            }
        }
    }
    return VyxPageShape { paramNames: names, paramTypes: types, hasLoad: vyxScriptHasLoad(script), loadRet: loadRet, layoutNone: layoutNone, err: "" }
}

/// Prefix `export ` onto a statement-leading `fn load` / `type Data` line so the
/// synthesized page module exports them (the router reaches them through the
/// page's namespace). Lines already `export`ed pass through.
fn vyxAutoExportPageDecls(script: String) -> String {
    let mut out = ""
    for line in vyxLines(script) {
        let t = vyxTrim(line)
        if vyxIsLayoutLine(line) {
            // The `layout="none"` opt-out directive is consumed by the router
            // shape; it is not valid Vyrn, so it never reaches the module.
        } else if t.startsWith("fn load") || t.startsWith("type Data") {
            out = out + "export " + line + "\n"
        } else {
            out = out + line + "\n"
        }
    }
    return out
}

/// The comma-joined `p.<name>` argument list forwarding a `Params` value into the
/// compiled page-body view fn.
fn vyxPageArgs(names: Array<String>) -> String {
    let mut parts: Array<String> = []
    for n in names {
        parts.push("p." + n)
    }
    return vyxJoin(parts, ", ")
}

// ===========================================================================
// The `head { … }` block (RFC-0041 §2) — a layout/page `<script>` may declare a
// small head block emitting `<link>`/`<meta>`/`<title>`/`<script>` into the
// document head that `std/ui` threads into `document(title, head, body)`. To keep
// the enclosing `<script>` section scannable, script includes use keyword forms
// (`module`/`script`) rather than literal `<script>…</script>` tags (whose close
// tag would truncate the section). Each entry is one statement-leading line:
//
//   head {
//       title: displayTitle(data)      // the document <title> (dynamic ok)
//       stylesheet "/theme.css"        // <link rel="stylesheet" href=…>
//       module "/app.js"               // <script type="module" src=…></script>
//       script "/legacy.js"            // <script src=…></script>
//   }
// ===========================================================================

/// One head entry: a `kind` (`stylesheet`/`module`/`script`) and its Vyrn source
/// `expr` (usually a string literal, but any String expression is legal).
type VyxHeadItem = { kind: String, expr: String }

/// A parsed head block: whether it declared a `title:`, that title expression,
/// the ordered head entries, and any diagnostic.
type VyxHead = { found: Bool, hasTitle: Bool, titleExpr: String, items: Array<VyxHeadItem>, err: String }

/// An empty head (no block present).
fn vyxNoHead() -> VyxHead {
    return VyxHead { found: false, hasTitle: false, titleExpr: "", items: [], err: "" }
}

/// Parse the body of a `head { … }` block (the text between its braces).
fn vyxParseHead(body: String, fileId: String) -> VyxHead {
    let mut hasTitle = false
    let mut titleExpr = ""
    let mut items: Array<VyxHeadItem> = []
    for line in vyxLines(body) {
        let t = vyxTrim(line)
        if t.length == 0 || t.startsWith("//") {
            // blank / comment
        } else if t.startsWith("title:") {
            hasTitle = true
            titleExpr = vyxTrim(vyxSlice(bytes(t), 6, bytes(t).length))
        } else if t.startsWith("stylesheet ") {
            items.push(VyxHeadItem { kind: "stylesheet", expr: vyxTrim(vyxSlice(bytes(t), 11, bytes(t).length)) })
        } else if t.startsWith("module ") {
            items.push(VyxHeadItem { kind: "module", expr: vyxTrim(vyxSlice(bytes(t), 7, bytes(t).length)) })
        } else if t.startsWith("script ") {
            items.push(VyxHeadItem { kind: "script", expr: vyxTrim(vyxSlice(bytes(t), 7, bytes(t).length)) })
        } else {
            return VyxHead { found: true, hasTitle: hasTitle, titleExpr: titleExpr, items: items, err: vyxErrDetail("VYX_BAD_HEAD_ENTRY", fileId, 0, t) }
        }
    }
    return VyxHead { found: true, hasTitle: hasTitle, titleExpr: titleExpr, items: items, err: "" }
}

/// A script with its `head { … }` block sliced out, plus the parsed head.
type VyxHeadSplit = { rest: String, head: VyxHead }

/// Locate + remove a statement-leading `head { … }` block from `script`,
/// returning the remaining script and the parsed head (found=false when absent).
fn vyxStripHead(script: String, fileId: String) -> VyxHeadSplit {
    let sb = bytes(script)
    let hb = vyxFindKwBlock(sb, "head")
    if hb.found == false || hb.malformed {
        return VyxHeadSplit { rest: script, head: vyxNoHead() }
    }
    let end = vyxMatchCurly(sb, hb.braceAt)
    let body = vyxSlice(sb, hb.braceAt + 1, end - 1)
    let rest = vyxSlice(sb, 0, hb.kwAt) + vyxSlice(sb, end, sb.length)
    return VyxHeadSplit { rest: rest, head: vyxParseHead(body, fileId) }
}

/// The `std/html` element expression for one head entry.
fn vyxHeadItemExpr(it: VyxHeadItem) -> String {
    if it.kind == "stylesheet" {
        return "el(\"link\", [A(\"rel\", \"stylesheet\"), A(\"href\", (" + it.expr + "))], [])"
    }
    if it.kind == "module" {
        return "el(\"script\", [A(\"type\", \"module\"), A(\"src\", (" + it.expr + "))], [])"
    }
    return "el(\"script\", [A(\"src\", (" + it.expr + "))], [])"
}

/// Emit the module's `head(<sig>) -> Array<Html>` and `headTitle(<sig>) -> String`
/// functions from a parsed head. `sig` is the parameter list (e.g. `p: Params, d:
/// Data`, or "" for a layout); `prelude` binds the flat locals the entry
/// expressions reference (`let id = p.id`, `let data = d`) so a `.vyx` page's head
/// can be dynamic in its params/data. Always emitted (empty head → `[]` / "").
fn vyxEmitHeadFns(head: VyxHead, sig: String, prelude: String) -> String {
    let mut out = "export fn head(" + sig + ") -> Array<Html> {\n" + prelude
    out = out + "    let mut uiHd: Array<Html> = []\n"
    for it in head.items {
        out = out + "    uiHd.push(" + vyxHeadItemExpr(it) + ")\n"
    }
    out = out + "    return uiHd\n}\n"
    out = out + "export fn headTitle(" + sig + ") -> String {\n" + prelude
    if head.hasTitle {
        out = out + "    return (" + head.titleExpr + ")\n}\n"
    } else {
        out = out + "    return \"\"\n}\n"
    }
    return out
}

/// Build a full `.vyx`-PAGE module (RFC-0039 §4). The template compiles to a
/// `uiPageBody(<params>[, data: Data])` view fn; the module exports `page`/`Params`
/// (and passes through `load`/`Data` auto-exported). EXPORTED so `std/ui`'s `pages`
/// gen fn synthesizes it from a nested `vyxPage(…)` import.
export fn vyxBuildPageModule(source: String, dir: String, themed: Bool, theme: String) -> String {
    let ba = bytes(source)
    let scriptSec = vyxSection(ba, "script", true)
    let templateSec = vyxSectionAvoid(ba, "template", false, scriptSec.start, scriptSec.end)
    if templateSec.found == false {
        return "VYX_PAGE_NO_TEMPLATE\n"
    }
    let templateBody = vyxSlice(ba, templateSec.start, templateSec.end)
    let script = if scriptSec.found { vyxSlice(ba, scriptSec.start, scriptSec.end) } else { "" }
    if scriptSec.found {
        let bad = vyxImportsFirstViolation(ba, scriptSec.start, scriptSec.end, "params")
        if bad > 0 {
            return vyxErr("VYX_IMPORTS_FIRST", "vyx_page", bad)
        }
    }

    // Pull the `params { … }` fields; the rest of the script (imports + helpers,
    // incl. load/Data) stays, with load/Data auto-exported.
    let sb = bytes(script)
    let pb = vyxFindKwBlock(sb, "params")
    let mut paramFields = ""
    let mut restScript = script
    if pb.found && pb.malformed == false {
        let end = vyxMatchCurly(sb, pb.braceAt)
        paramFields = vyxTrim(vyxSlice(sb, pb.braceAt + 1, end - 1))
        restScript = vyxSlice(sb, 0, pb.kwAt) + vyxSlice(sb, end, sb.length)
    }
    // Pull the `head { … }` block (RFC-0041 §2) out of the remaining script — its
    // entries become the module's `head()`/`headTitle()`, and it must not reach
    // the compiled body as pass-through source.
    let hs = vyxStripHead(restScript, "vyx_page")
    if hs.head.err != "" {
        return hs.head.err
    }
    restScript = hs.rest
    let hasLoad = vyxScriptHasLoad(script)
    let restExported = vyxAutoExportPageDecls(restScript)

    // The synthetic component: a `props` block of the params (+ a `data: Data`
    // param when there is a loader) drives the compiled view fn's parameters.
    let dataField = if hasLoad {
        if paramFields.length > 0 { ", data: Data" } else { "data: Data" }
    } else {
        ""
    }
    let propsInner = paramFields + dataField
    let mut synthScript = restExported
    if propsInner.length > 0 {
        // The synthetic component's `props` block trails the page's own imports so
        // it satisfies the imports-first rule (RFC-0040 §3); the emitted module is
        // order-independent (imports and helpers are collected separately).
        synthScript = restExported + "props { " + propsInner + " }\n"
    }
    let synthSource = "<script>\n" + synthScript + "\n</script>\n<template>\n" + templateBody + "\n</template>\n"
    let comp = vyxCompileComponent("UiPageBody", synthSource, dir)
    if comp.err != "" {
        return comp.err
    }
    let moduleStr = vyxBuildModule([comp], themed, theme)
    if moduleStr.contains("export fn uiPageBody") == false {
        // vyxBuildModule returned a diagnostic (identifier lines), not a module.
        return moduleStr
    }

    // Parse the param field NAMES (for the Params type + the page's forwarding).
    let mut paramNames: Array<String> = []
    if paramFields.length > 0 {
        for part in vyxSplitFields(paramFields) {
            let t = vyxTrim(part)
            if t.length > 0 {
                let pbf = bytes(t)
                let mut colon = 0 - 1
                let mut k = 0
                while k < pbf.length && colon < 0 {
                    if pbf[k] == 58 {
                        colon = k
                    }
                    k = k + 1
                }
                if colon >= 0 {
                    paramNames.push(vyxTrim(vyxSlice(pbf, 0, colon)))
                }
            }
        }
    }

    let mut out = moduleStr
    if paramFields.length > 0 {
        out = out + "export type Params = { " + paramFields + " }\n"
    }
    // The page entry the router calls, forwarding the Params fields (and the
    // loaded Data when there is a loader) into the compiled body.
    if hasLoad {
        let args = if paramNames.length > 0 { vyxPageArgs(paramNames) + ", d" } else { "d" }
        out = out + "export fn page(p: Params, d: Data) -> Html {\n    return uiPageBody(" + args + ")\n}\n"
    } else if paramNames.length > 0 {
        out = out + "export fn page(p: Params) -> Html {\n    return uiPageBody(" + vyxPageArgs(paramNames) + ")\n}\n"
    } else {
        out = out + "export fn page() -> Html {\n    return uiPageBody()\n}\n"
    }
    // The `head()`/`headTitle()` pair (RFC-0041 §2), taking the same shape as
    // `page` so a dynamic head can read the params/loaded data. `std/ui` threads
    // the result into `document(title, head, body)`.
    let sig = if hasLoad { "p: Params, d: Data" } else { if paramNames.length > 0 { "p: Params" } else { "" } }
    let mut prelude = ""
    for n in paramNames {
        prelude = prelude + "    let " + n + " = p." + n + "\n"
    }
    if hasLoad {
        prelude = prelude + "    let data = d\n"
    }
    out = out + vyxEmitHeadFns(hs.head, sig, prelude)
    return out
}

/// `vyxPage(vyxPath)` — synthesize a `.vyx` page module from the file at
/// `vyxPath` (RFC-0039 §4). A `gen fn` (its `readFile` is comptime-only). The
/// FULL `.vyx` path is the constant argument (not the stem), because the generator
/// sandbox admits reads of exactly its path arguments — reading `arg + ".vyx"`
/// would escape the declared inputs. `std/ui`'s `pages` imports this per `.vyx`
/// page: `import * as p<n> from vyxPage("routes/foo.vyx")`.
export gen fn vyxPage(vyxPath: String) -> String {
    let src = match readFile(vyxPath) {
        Ok(v) => v,
        Err(e) => "",
    }
    let dir = vyxDirOf(vyxPath)
    return vyxBuildPageModule(src, dir, false, "")
}

/// `vyxPageThemed(vyxPath, theme)` — the themed variant (RFC-0036): the page
/// body's classes are compile-checked against `theme`.
export gen fn vyxPageThemed(vyxPath: String, theme: String) -> String {
    let src = match readFile(vyxPath) {
        Ok(v) => v,
        Err(e) => "",
    }
    let dir = vyxDirOf(vyxPath)
    return vyxBuildPageModule(src, dir, true, theme)
}

/// The directory portion of `path` (everything before the last `/`), so relative
/// imports in a `.vyx` page rebase against the page's directory.
fn vyxDirOf(path: String) -> String {
    let ba = bytes(path)
    let slash = vyxFindLast(ba, bytes("/"), 0)
    if slash < 0 {
        return "."
    }
    return vyxSlice(ba, 0, slash)
}

// ===========================================================================
// `.vyx` LAYOUTS (RFC-0041 §1) — a `layout.vyx` is a `.vyx` component with a
// `<slot/>` (where the page body renders) and an optional `head { … }`. It is NOT
// a route. `std/ui`'s router imports each layout through a nested `vyxLayout(…)`
// generator import and wraps every page body (nearest-ancestor first, composing
// outermost-last) in `layout(children)` before `document(…)`.
// ===========================================================================

/// Build a `.vyx`-LAYOUT module: `layout(children: Array<Html>) -> Html` around
/// the compiled template (which must contain `<slot/>`), plus `head()`/
/// `headTitle()` from its head block. EXPORTED so `std/ui`'s router synthesizes it
/// from a nested `vyxLayout(…)` import.
export fn vyxBuildLayoutModule(source: String, dir: String, themed: Bool, theme: String) -> String {
    let ba = bytes(source)
    let scriptSec = vyxSection(ba, "script", true)
    let templateSec = vyxSectionAvoid(ba, "template", false, scriptSec.start, scriptSec.end)
    if templateSec.found == false {
        return "VYX_LAYOUT_NO_TEMPLATE\n"
    }
    let templateBody = vyxSlice(ba, templateSec.start, templateSec.end)
    let script = if scriptSec.found { vyxSlice(ba, scriptSec.start, scriptSec.end) } else { "" }

    // Pull the head block; the rest is imports + helpers (passed through).
    let hs = vyxStripHead(script, "vyx_layout")
    if hs.head.err != "" {
        return hs.head.err
    }
    let synthSource = "<script>\n" + hs.rest + "\n</script>\n<template>\n" + templateBody + "\n</template>\n"
    let comp = vyxCompileComponent("UiLayoutBody", synthSource, dir)
    if comp.err != "" {
        return comp.err
    }
    // A layout MUST render the page body through a `<slot/>`.
    if comp.takesChildren == false {
        return "VYX_LAYOUT_NO_SLOT__" + vyxIdentOf(dir) + "\n"
    }
    let moduleStr = vyxBuildModule([comp], themed, theme)
    if moduleStr.contains("export fn uiLayoutBody") == false {
        return moduleStr
    }
    let mut out = moduleStr
    out = out + "export fn layout(children: Array<Html>) -> Html {\n    return uiLayoutBody(children)\n}\n"
    out = out + vyxEmitHeadFns(hs.head, "", "")
    return out
}

/// `vyxLayout(vyxPath)` — synthesize a `.vyx` layout module (RFC-0041 §1). A
/// `gen fn` (its `readFile` is comptime-only).
export gen fn vyxLayout(vyxPath: String) -> String {
    let src = match readFile(vyxPath) {
        Ok(v) => v,
        Err(e) => "",
    }
    return vyxBuildLayoutModule(src, vyxDirOf(vyxPath), false, "")
}

/// `vyxLayoutThemed(vyxPath, theme)` — the themed layout variant (RFC-0036): the
/// layout's template classes are compile-checked against `theme`.
export gen fn vyxLayoutThemed(vyxPath: String, theme: String) -> String {
    let src = match readFile(vyxPath) {
        Ok(v) => v,
        Err(e) => "",
    }
    return vyxBuildLayoutModule(src, vyxDirOf(vyxPath), true, theme)
}

// ===========================================================================
// `.vyx` ERROR PAGES (RFC-0041 §3) — an `error.vyx` is a `.vyx` component the
// router renders (in place of the page, wrapped in the same layout) when a page's
// `load` fails. The framework injects an `error: PageError` prop (imported from
// `std/ui`); the template reads `error.status` / `error.message`. It is NOT a
// route.
// ===========================================================================

/// Build a `.vyx`-ERROR module: `errorPage(e: PageError) -> Html` around the
/// compiled template, with an injected `error: PageError` prop. EXPORTED so
/// `std/ui`'s router synthesizes it from a nested `vyxError(…)` import.
export fn vyxBuildErrorModule(source: String, dir: String, themed: Bool, theme: String) -> String {
    let ba = bytes(source)
    let scriptSec = vyxSection(ba, "script", true)
    let templateSec = vyxSectionAvoid(ba, "template", false, scriptSec.start, scriptSec.end)
    if templateSec.found == false {
        return "VYX_ERROR_NO_TEMPLATE\n"
    }
    let templateBody = vyxSlice(ba, templateSec.start, templateSec.end)
    let script = if scriptSec.found { vyxSlice(ba, scriptSec.start, scriptSec.end) } else { "" }

    // Strip any head block (error pages render inside the layout, which owns the
    // head), then inject the `error: PageError` prop and its import.
    let hs = vyxStripHead(script, "vyx_error")
    if hs.head.err != "" {
        return hs.head.err
    }
    let synthScript = "import { PageError } from \"std/ui\"\n" + hs.rest + "\nprops { error: PageError }\n"
    let synthSource = "<script>\n" + synthScript + "\n</script>\n<template>\n" + templateBody + "\n</template>\n"
    let comp = vyxCompileComponent("UiErrorBody", synthSource, dir)
    if comp.err != "" {
        return comp.err
    }
    let moduleStr = vyxBuildModule([comp], themed, theme)
    if moduleStr.contains("export fn uiErrorBody") == false {
        return moduleStr
    }
    let mut out = moduleStr
    out = out + "export fn errorPage(e: PageError) -> Html {\n    return uiErrorBody(e)\n}\n"
    return out
}

/// `vyxError(vyxPath)` — synthesize a `.vyx` error-page module (RFC-0041 §3).
export gen fn vyxError(vyxPath: String) -> String {
    let src = match readFile(vyxPath) {
        Ok(v) => v,
        Err(e) => "",
    }
    return vyxBuildErrorModule(src, vyxDirOf(vyxPath), false, "")
}

/// `vyxErrorThemed(vyxPath, theme)` — the themed error-page variant (RFC-0036).
export gen fn vyxErrorThemed(vyxPath: String, theme: String) -> String {
    let src = match readFile(vyxPath) {
        Ok(v) => v,
        Err(e) => "",
    }
    return vyxBuildErrorModule(src, vyxDirOf(vyxPath), true, theme)
}

// ===========================================================================
// Tests — the pure helpers (parsing + codegen) are covered without file I/O by
// feeding them source strings directly.
// ===========================================================================

test "section extraction finds script and template bounds" {
    let src = "<script>props { x: Int64 }</script>\n<template><li>hi</li></template>"
    let ba = bytes(src)
    let s = vyxSection(ba, "script", true)
    let t = vyxSection(ba, "template", false)
    assert(s.found)
    assert(t.found)
    assertEq(vyxSlice(ba, t.start, t.end), "<li>hi</li>")
}

test "props parse pulls names and types" {
    let sc = vyxParseScript("props { item: Item, count: Int64 }", "./components", "c_vyx")
    assertEq(sc.err, "")
    assertEq(sc.propNames.length, 2)
    assertEq(sc.propNames[0], "item")
    assertEq(sc.propTypes[0], "Item")
    assertEq(sc.propNames[1], "count")
    assertEq(sc.propTypes[1], "Int64")
}

test "relative imports are rebased, bare imports pass through" {
    assertEq(vyxRebaseImport("import { t } from \"../i18n\"", "./components"), "import { t } from \"./components/../i18n\"")
    assertEq(vyxRebaseImport("import { x } from \"std/html\"", "./components"), "import { x } from \"std/html\"")
}

test "a simple component compiles to a view function" {
    let src = "<script>props { title: String }</script><template><li class=\"row\">{{ title }}</li></template>"
    let comp = vyxCompileComponent("Item", src, "./c")
    assertEq(comp.err, "")
    assertEq(comp.fnName, "item")
    assertEq(comp.takesChildren, false)
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("export fn item(title: String) -> Html"))
    assert(out.contains("Cls(\"row\")"))
    assert(out.contains("text((title).toString())"))
}

test "a themed build routes class through vyxTheme.cls with its own origin directive" {
    let src = "<script>props { title: String }</script><template><li class=\"row\">{{ title }}</li></template>"
    let comp = vyxCompileComponent("Item", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], true, "./theme.json")
    assert(out.contains("import { tw } from \"std/tw\""))
    assert(out.contains("import * as vyxTheme from tw(\"./theme.json\")"))
    assert(out.contains("vyxTheme.cls(\"row\")"))
    assert(out.contains(": Attr = vyxTheme.cls(\"row\")"))
    assert(out.contains("//@origin ./c/Item.vyx:1:"))
    let bare = vyxBuildModule([comp], false, "")
    assert(bare.contains("Cls(\"row\")"))
    assertEq(bare.contains("vyxTheme"), false)
}

test "a themed build coerces a dynamic class at runtime" {
    let src = "<script>props { cls: String }</script><template><li :class=\"cls\">x</li></template>"
    let comp = vyxCompileComponent("Item", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], true, "./theme.json")
    assert(out.contains("vyxTheme.cls(cls)"))
}

test "a v-if chain lowers to nested conditionals" {
    let src = "<template><ul><b v-if=\"n > 1\">many</b><i v-else>one</i></ul></template>"
    let comp = vyxCompileComponent("Lst", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("if n > 1 {"))
    assert(out.contains("} else {"))
}

test "a v-else-if condition maps to its own origin column" {
    let src = "<template>\n<ul>\n<b v-if=\"n > 5\">hi</b>\n<i v-else-if=\"n > 1\">mid</i>\n</ul>\n</template>"
    let comp = vyxCompileComponent("Lst", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("} else if n > 1 {"))
    // The v-else-if condition is on line 4; `<i v-else-if="` is 14 chars so the
    // condition starts at column 15.
    assert(out.contains("//@origin ./c/Lst.vyx:4:15"))
}

test "a keyed v-for lowers to keyed pushes" {
    let src = "<template><ul><li v-for=\"x in xs\" :key=\"x.id\">{{ x.name }}</li></ul></template>"
    let comp = vyxCompileComponent("Lst", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("for x in xs {"))
    assert(out.contains("keyed((x.id).toString()"))
}

test "an event handler lowers to On with a scalar payload" {
    let src = "<template><button @click=\"remove(item.id)\">x</button></template>"
    let comp = vyxCompileComponent("Btn", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("On(\"click\", \"remove\", (item.id).toString())"))
}

test "a bad event arg maps column-exact to the .vyx" {
    // `<button @click="` is 16 chars; the arg `item.id` begins at column 17.
    let src = "<template><button @click=\"remove(item.id)\">x</button></template>"
    let comp = vyxCompileComponent("Btn", src, "./c")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("//@origin ./c/Btn.vyx:1:34"))
}

test "a missing v-for key is a generation diagnostic" {
    let src = "<template><ul><li v-for=\"x in xs\">{{ x }}</li></ul></template>"
    let comp = vyxCompileComponent("Lst", src, "./c")
    assert(comp.err.contains("VYX_MISSING_FOR_KEY"))
}

test "a dangling v-else is a named diagnostic" {
    let src = "<template><ul><i v-else>x</i></ul></template>"
    let comp = vyxCompileComponent("Bad", src, "./c")
    assert(comp.err.contains("VYX_DANGLING_ELSE"))
}

test "multiple roots are rejected" {
    let src = "<template><li>a</li><li>b</li></template>"
    let comp = vyxCompileComponent("Two", src, "./c")
    assert(comp.err.contains("VYX_MULTIPLE_ROOTS"))
}

test "an unclosed element is rejected" {
    let src = "<template><li>oops</template>"
    let comp = vyxCompileComponent("Bad", src, "./c")
    assert(comp.err.contains("VYX_UNCLOSED_ELEMENT"))
}

test "a props block before an import is a named diagnostic (imports first)" {
    let src = "<script>\nprops { x: Int64 }\nimport { t } from \"../s\"\n</script>\n<template><li>{{ x }}</li></template>"
    let comp = vyxCompileComponent("Bad", src, "./c")
    assert(comp.err.contains("VYX_IMPORTS_FIRST"))
    assert(comp.err.contains("Bad_vyx"))
    assert(comp.err.contains("line_3"))
}

test "imports before a props block compile" {
    let src = "<script>\nimport { t } from \"../s\"\nprops { x: Int64 }\n</script>\n<template><li>{{ x }}</li></template>"
    let comp = vyxCompileComponent("Ok", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("export fn ok(x: Int64) -> Html"))
    assert(out.contains("from \"./c/../s\""))
}

test "a props keyword in a comment does not trip imports-first" {
    let src = "<script>\nimport { t } from \"../s\"\n// props go here\nprops { x: Int64 }\n</script>\n<template><li>{{ x }}</li></template>"
    let comp = vyxCompileComponent("Ok", src, "./c")
    assertEq(comp.err, "")
}

test "a .vyx page with params before an import is rejected" {
    let src = "<script>\nparams { id: String }\nimport { Paste } from \"../wire\"\n</script>\n<template><h1>{{ id }}</h1></template>"
    let out = vyxBuildPageModule(src, "./routes", false, "")
    assert(out.contains("VYX_IMPORTS_FIRST"))
}

test "a .vyx page with imports before params compiles" {
    let src = "<script>\nimport { Paste } from \"../wire\"\nparams { id: String }\n</script>\n<template><h1>{{ id }}</h1></template>"
    let out = vyxBuildPageModule(src, "./routes", false, "")
    assert(out.contains("export fn page"))
}

test "a non-scalar event arg is rejected" {
    let src = "<template><button @click=\"go(a, b)\">x</button></template>"
    let comp = vyxCompileComponent("Btn", src, "./c")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("VYX_NON_SCALAR_EVENT_ARG"))
}

test "an unknown component tag is rejected" {
    let src = "<template><ul><Missing :x=\"1\"/></ul></template>"
    let comp = vyxCompileComponent("Host", src, "./c")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("VYX_UNKNOWN_COMPONENT"))
}

test "a component uses children when the template has a slot" {
    let src = "<template><section><slot/></section></template>"
    let comp = vyxCompileComponent("Shell", src, "./c")
    assertEq(comp.err, "")
    assert(comp.takesChildren)
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("export fn shell(children: Array<Html>) -> Html"))
}

test "v-html lowers to a Raw content node" {
    let src = "<script>props { html: String }</script><template><div v-html=\"html\"></div></template>"
    let comp = vyxCompileComponent("R", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("Raw(html)"))
}

test "a dynamic attr is hoisted under an origin directive" {
    let src = "<script>props { u: String }</script><template><a :href=\"u\">x</a></template>"
    let comp = vyxCompileComponent("Lnk", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("A(\"href\", u)"))
}

test "a single-quoted attr value carries a string literal expression" {
    let src = "<script>props { id: String }</script><template><a :href='\"/raw/\" + id'>raw</a></template>"
    let comp = vyxCompileComponent("Lnk", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("A(\"href\", \"/raw/\" + id)"))
}

// ---- RFC-0039 §2: the real scanner — comments/strings never miscompile ------

test "a comment mentioning props before the real props block is ignored" {
    let src = "<script>\n// these are the props for the widget\nprops { title: String }\n</script>\n<template><li>{{ title }}</li></template>"
    let comp = vyxCompileComponent("C", src, "./c")
    assertEq(comp.err, "")
    assertEq(comp.propNames.length, 1)
    assertEq(comp.propNames[0], "title")
}

test "a comment mentioning props in a no-props component is ignored" {
    let src = "<script>\n// no props here, just a helper\nfn greet() -> String { return \"hi\" }\n</script>\n<template><li>{{ greet() }}</li></template>"
    let comp = vyxCompileComponent("C", src, "./c")
    assertEq(comp.err, "")
    assertEq(comp.propNames.length, 0)
}

test "a helper identifier named props is not a props block" {
    let src = "<script>\nfn f() -> Int64 {\nlet props = 5\nreturn props\n}\n</script>\n<template><li>{{ f() }}</li></template>"
    let comp = vyxCompileComponent("C", src, "./c")
    assertEq(comp.err, "")
    assertEq(comp.propNames.length, 0)
    assert(comp.helpers.contains("let props = 5"))
}

test "an HTML comment inside the template is stripped, not a bad tag" {
    let src = "<template><ul><!-- a note --><li>x</li></ul></template>"
    let comp = vyxCompileComponent("C", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("text(\"x\")"))
}

test "a lone brace in text stays literal" {
    let src = "<template><li>a { b } c</li></template>"
    let comp = vyxCompileComponent("C", src, "./c")
    assertEq(comp.err, "")
    let out = vyxBuildModule([comp], false, "")
    assert(out.contains("a { b } c"))
}

test "a literal close-script tag inside a helper string does not truncate the section" {
    let src = "<script>\nfn f() -> String { return \"</script>\" }\n</script>\n<template><li>{{ f() }}</li></template>"
    let ba = bytes(src)
    let s = vyxSection(ba, "script", true)
    assert(s.found)
    // The section must reach past the string literal to the real closing tag.
    assert(vyxSlice(ba, s.start, s.end).contains("return"))
}

test "a helper string containing props-brace and template tags is inert" {
    // The scanner never keyword-matches inside a string literal: a helper string
    // spelling `props {`, `<template>`, or `</script>`-adjacent words compiles as
    // plain data, with no props block conjured and no section confusion.
    let src = "<script>\nfn f() -> String { return \"props { fake: Int64 } <template> script\" }\n</script>\n<template><li>{{ f() }}</li></template>"
    let comp = vyxCompileComponent("C", src, "./c")
    assertEq(comp.err, "")
    assertEq(comp.propNames.length, 0)
    assert(comp.helpers.contains("props { fake: Int64 }"))
}

test "comments may mention props template and script freely (the CreateForm regression)" {
    // The RFC-0039 §2 regression: a comment naming all three section keywords
    // parses to the same component as a file without it (same props, same view
    // fn — the comment line passes through into the helpers as inert Vyrn).
    let src = "<script>\n// the props for this template's script are below\nprops { title: String }\n</script>\n<template><li>{{ title }}</li></template>"
    let withComment = vyxCompileComponent("C", src, "./c")
    let bare = vyxCompileComponent("C", "<script>\nprops { title: String }\n</script>\n<template><li>{{ title }}</li></template>", "./c")
    assertEq(withComment.err, "")
    assertEq(withComment.propNames.length, 1)
    assertEq(withComment.propNames[0], "title")
    let a = vyxBuildModule([withComment], false, "")
    let b = vyxBuildModule([bare], false, "")
    // Identical view function; only the pass-through comment line may differ.
    assert(a.contains("export fn c(title: String) -> Html"))
    assert(b.contains("export fn c(title: String) -> Html"))
}

test "identical imports collapse and same-spec selective imports union" {
    let a = vyxCompileComponent("A", "<script>import { x } from \"std/html\"\nimport { t } from \"../s\"</script><template><li>{{ x }}</li></template>", "./w")
    let b = vyxCompileComponent("B", "<script>import { y } from \"std/html\"\nimport { t } from \"../s\"</script><template><li>{{ y }}</li></template>", "./w")
    let out = vyxBuildModule([a, b], false, "")
    // The two std/html selective imports union into one line.
    assert(out.contains("import { x, y } from \"std/html\""))
    // The identical `../s` import (rebased to the same spec) appears once.
    assertEq(out.contains("import { t } from \"./w/../s\""), true)
}

test "a same-name-different-spec import conflict names both files" {
    let a = vyxCompileComponent("A", "<script>import { t } from \"../one\"</script><template><li>{{ t }}</li></template>", "./w")
    let b = vyxCompileComponent("B", "<script>import { t } from \"../two\"</script><template><li>{{ t }}</li></template>", "./w")
    let out = vyxBuildModule([a, b], false, "")
    assert(out.contains("VYX_IMPORT_CONFLICT"))
    assert(out.contains("A_vyx"))
    assert(out.contains("B_vyx"))
}

// ---- RFC-0039 §4: .vyx pages ------------------------------------------------

test "a .vyx page shape reports its params and loader" {
    let src = "<script>\nparams { id: String }\nexport fn load(p: Params) -> Validation<Data> { return valid }\ntype Data = { title: String }\n</script>\n<template><h1>{{ data.title }}</h1></template>"
    let shape = vyxPageShape(src)
    assertEq(shape.err, "")
    assertEq(shape.paramNames.length, 1)
    assertEq(shape.paramNames[0], "id")
    assertEq(shape.paramTypes[0], "String")
    assert(shape.hasLoad)
}

test "a .vyx page module exports Params and a page fn binding the segment" {
    let src = "<script>\nparams { id: String }\n</script>\n<template><h1>paste {{ id }}</h1></template>"
    let out = vyxBuildPageModule(src, "./routes/p", false, "")
    assert(out.contains("export type Params = { id: String }"))
    assert(out.contains("export fn uiPageBody(id: String) -> Html"))
    assert(out.contains("export fn page(p: Params) -> Html"))
    assert(out.contains("return uiPageBody(p.id)"))
}

test "a .vyx page with a loader forwards Data and auto-exports load and Data" {
    let src = "<script>\nparams { id: Int64 }\nfn load(p: Params) -> Validation<Data> { return valid }\ntype Data = { title: String }\n</script>\n<template><h1>{{ data.title }}</h1></template>"
    let out = vyxBuildPageModule(src, "./routes/book", false, "")
    assert(out.contains("export fn page(p: Params, d: Data) -> Html"))
    assert(out.contains("return uiPageBody(p.id, d)"))
    assert(out.contains("export fn load(p: Params)"))
    assert(out.contains("export type Data"))
}

test "a static .vyx page needs no Params" {
    let src = "<template><h1>about</h1></template>"
    let out = vyxBuildPageModule(src, "./routes", false, "")
    assert(out.contains("export fn page() -> Html"))
    assertEq(out.contains("export type Params"), false)
}
