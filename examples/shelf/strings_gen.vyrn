/// PRE-GENERATED i18n module (from `strings/en.json` + `strings/uk.json`).
///
/// WORKAROUND for two compiler bugs (see rfcs/NOTES-dogfood-shelf.md, BUGS):
///   * `std/i18n` cannot be linked with `std/html`: std/i18n's LOCAL `on`
///     variable is mis-resolved as std/html's exported `on()`. Importing the
///     GENERATED module (this file) instead of the `i18n(..)` generator keeps
///     `std/i18n.vyrn` out of the runtime link, dodging it.
///   * this module's exported `t()` collided with a LOCAL `t` loop variable in
///     `std/ui` (same flat-namespace shadowing bug), so it is renamed to `tr()`.
/// AND: a pre-generated module is non-root, so it may NOT keep the generator's
/// `currentLocale` module state (state is root-only). The stateful `setLocale`/
/// `locale()`/`currentLocale` were therefore stripped and every accessor now
/// takes an explicit `loc: Locale` — the caller (root) holds the current locale.
/// Regenerate after editing the JSON:  vyrn emit-gen <a file importing i18n("./strings")>
///   then re-apply: rename `t`->`tr`; drop `currentLocale`/`setLocale`/`locale`;
///   thread `loc: Locale` (replace `match currentLocale` with `match loc`).
///   (This whole ceremony IS the friction the report is about.)
/// Generated by std/i18n `i18n` (RFC-0020 M2) — do not edit.
export type Locale =
    | En
    | Uk
export type TransKey = String where value =~ "(app\\.title|app\\.tagline|nav\\.home\\.label|nav\\.about\\.label|shelf\\.count|shelf\\.empty|shelf\\.tags|shelf\\.add|shelf\\.title|shelf\\.url|shelf\\.tagsField|shelf\\.save|shelf\\.rateLabel|shelf\\.unrated|shelf\\.delete|shelf\\.confirm|shelf\\.cancel|shelf\\.filterAll|tag\\.fiction|tag\\.reference|tag\\.web|book\\.notFound|book\\.reserved|lang\\.switch)"
fn tAppTitle__En() -> String {
    let mut acc = ""
    acc = acc + "Shelf"
    return acc
}
fn tAppTitle__Uk() -> String {
    let mut acc = ""
    acc = acc + "Полиця"
    return acc
}
