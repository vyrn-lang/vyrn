fn tShelfCount__En(n: Int64) -> String {
    let mut acc = ""
    if n == 1 {
        acc = acc + n.toString()
        acc = acc + " book"
    } else {
        acc = acc + n.toString()
        acc = acc + " books"
    }
    return acc
}
fn tShelfCount__Uk(n: Int64) -> String {
    let mut acc = ""
    if n % 10 == 1 && n % 100 != 11 {
        acc = acc + n.toString()
        acc = acc + " книга"
    } else if n % 10 >= 2 && n % 10 <= 4 && (n % 100 < 12 || n % 100 > 14) {
        acc = acc + n.toString()
        acc = acc + " книги"
    } else if n % 10 == 0 || (n % 10 >= 5 && n % 10 <= 9) || (n % 100 >= 11 && n % 100 <= 14) {
        acc = acc + n.toString()
        acc = acc + " книг"
    } else {
        acc = acc + n.toString()
        acc = acc + " книги"
    }
    return acc
}
/// {n, plural, one {# book} other {# books}}
export fn tShelfCount(loc: Locale, n: Int64) -> String {
    return match loc {
        En => tShelfCount__En(n),
        Uk => tShelfCount__Uk(n),
    }
}
