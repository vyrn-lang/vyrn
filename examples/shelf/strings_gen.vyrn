    }
    if s == "shelf.save" {
        return Some(s)
    }
    if s == "shelf.rateLabel" {
        return Some(s)
    }
    if s == "shelf.unrated" {
        return Some(s)
    }
    if s == "shelf.delete" {
        return Some(s)
    }
    if s == "shelf.confirm" {
        return Some(s)
    }
    if s == "shelf.cancel" {
        return Some(s)
    }
    if s == "shelf.filterAll" {
        return Some(s)
    }
    if s == "tag.fiction" {
        return Some(s)
    }
    if s == "tag.reference" {
        return Some(s)
    }
    if s == "tag.web" {
        return Some(s)
    }
    if s == "book.notFound" {
        return Some(s)
    }
    if s == "book.reserved" {
        return Some(s)
    }
    if s == "lang.switch" {
        return Some(s)
    }
    return None
