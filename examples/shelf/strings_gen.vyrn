export fn tr(loc: Locale, key: TransKey) -> String {
    if key == "app.title" {
        return match loc {
            En => "Shelf",
            Uk => "Полиця",
        }
    }
    if key == "app.tagline" {
        return match loc {
            En => "A tiny library of books and bookmarks.",
            Uk => "Маленька бібліотека книжок і закладок.",
        }
    }
    if key == "nav.home.label" {
        return match loc {
            En => "Shelf",
            Uk => "Полиця",
        }
    }
    if key == "nav.about.label" {
        return match loc {
            En => "About",
            Uk => "Про застосунок",
        }
    }
    if key == "shelf.count" {
        return "{n, plural, one {# book} other {# books}}"
    }
    if key == "shelf.empty" {
        return match loc {
            En => "No books yet — add one below.",
            Uk => "Ще немає книжок — додайте нижче.",
        }
    }
    if key == "shelf.tags" {
        return match loc {
            En => "Tags",
            Uk => "Теги",
        }
    }
    if key == "shelf.add" {
        return match loc {
            En => "Add a book",
            Uk => "Додати книгу",
        }
    }
    if key == "shelf.title" {
        return match loc {
            En => "Title",
            Uk => "Назва",
        }
    }
    if key == "shelf.url" {
        return match loc {
            En => "URL",
            Uk => "Посилання",
        }
    }
    if key == "shelf.tagsField" {
        return match loc {
            En => "Tags (comma separated)",
            Uk => "Теги (через кому)",
        }
    }
    if key == "shelf.save" {
        return match loc {
            En => "Save",
            Uk => "Зберегти",
        }
    }
    if key == "shelf.rateLabel" {
        return match loc {
            En => "Rate",
            Uk => "Оцінити",
        }
    }
    if key == "shelf.unrated" {
        return match loc {
            En => "unrated",
            Uk => "без оцінки",
        }
    }
    if key == "shelf.delete" {
        return match loc {
            En => "Delete",
            Uk => "Видалити",
        }
    }
    if key == "shelf.confirm" {
        return match loc {
            En => "Really delete?",
            Uk => "Точно видалити?",
        }
    }
    if key == "shelf.cancel" {
        return match loc {
            En => "Cancel",
            Uk => "Скасувати",
        }
    }
    if key == "shelf.filterAll" {
        return match loc {
            En => "all",
            Uk => "усі",
        }
    }
    if key == "tag.fiction" {
        return match loc {
            En => "Fiction",
            Uk => "Художня",
        }
    }
    if key == "tag.reference" {
        return match loc {
            En => "Reference",
            Uk => "Довідник",
        }
    }
    if key == "tag.web" {
        return match loc {
            En => "Web",
            Uk => "Веб",
        }
    }
    if key == "book.notFound" {
        return "No book with id {id}."
    }
    if key == "book.reserved" {
        return "Id {id} is reserved and cannot be shown."
    }
    if key == "lang.switch" {
        return match loc {
            En => "Мова: українська",
            Uk => "Language: English",
        }
    }
    return key
}
export fn transKey(s: String) -> Option<TransKey> {
