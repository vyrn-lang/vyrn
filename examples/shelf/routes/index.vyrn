/// GET / — the home page. The loader reads the books store through the contract
/// accessors and server-renders the shelf list; the browser client mounts into
/// #app for the interactive version (add / rate / delete / filter / locale).
import { homePage } from "../view"
import { listBooks, tagCounts } from "../contract"
import { Html } from "std/html"

export fn page() -> Html {
    return homePage(listBooks(), tagCounts())
}
