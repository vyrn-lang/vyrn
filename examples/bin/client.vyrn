/// The browser client root: the create island that hydrates #app on the home
/// page. It holds the draft form state, validates the draft with fromJson, fires
/// the typed createPaste stub with a completion callback, and on success asks the
/// host to soft-navigate to the new paste via the takeNav extern.
import { rpcClient } from "std/rpc"
import * as api from rpcClient("./contract")
import { componentsThemed } from "std/vyx"
import { createForm } from componentsThemed("./widgets", "./theme.json")
import { Html, toHtmlString, diff } from "std/html"

/// An unvalidated mirror of CreateReq — constructing it never traps, so a bad
/// draft can be encoded and run through fromJson to surface Issues instead.
type RawCreate = { title: String, body: String, lang: String }

// ---- client view state (module state) --------------------------------------

let mut draftTitle: String = ""
let mut draftBody: String = ""
let mut draftLang: String = "text"

/// The current rejection, structured so the form attaches each issue to its field
/// (RFC-0068). A client-side prevalidation and a server 422 both land here as the
/// SAME `Array<RpcIssue>`, so the form renders one shape whichever side rejected.
let mut issues: Array<api.RpcIssue> = []

/// The soft-nav target after a successful create, or "" for none. takeNav hands
/// it to the host, which clears it.
let mut navTarget: String = ""

/// The retained previous view, for the patch protocol.
let mut lastTree: Html = Empty

// ---- helpers ---------------------------------------------------------------

/// Wrap a single non-field message (a transport `Failed`, or an app-level `Err`
/// carried on a 200) as a form-level issue (empty path), so it renders through the
/// SAME field-attached path — an empty path matches no field, so the form shows it
/// on its form-level line.
fn oneIssue(msg: String) -> Array<api.RpcIssue> {
    return [api.RpcIssue { key: "app", path: "", message: msg }]
}

// ---- the view --------------------------------------------------------------

fn view() -> Html {
    return createForm(draftTitle, draftLang, draftBody, issues)
}

// ---- RPC completion callback ------------------------------------------------

/// Passed to api.createPaste at the call site. The home list and paste view are
/// server-rendered, so listPastes/getPaste need no client callback.
fn onCreatePaste(res: api.RpcReply<api.PasteResult>) {
    match res {
        Done(r) => afterCreate(r),
        Rejected(iss) => setIssues(iss),
        Failed(msg) => setIssues(oneIssue(msg)),
    }
}
fn afterCreate(r: api.PasteResult) {
    match r {
        Ok(p) => goToPaste(p),
        Err(why) => setIssues(oneIssue(why)),
    }
}
fn goToPaste(p: api.Paste) {
    navTarget = "/p/\{p.id}"
}
fn setIssues(s: Array<api.RpcIssue>) {
    issues = s
}

// ---- event handlers (exported to JS, one String arg) ------------------------

export extern fn setDraftTitle(arg: String) {
    draftTitle = arg
}
export extern fn setDraftBody(arg: String) {
    draftBody = arg
}
export extern fn setDraftLang(arg: String) {
    draftLang = arg
}

/// Validate the draft with fromJson; valid => fire the typed stub, invalid =>
/// surface the Issues in the form.
export extern fn submitCreate(arg: String) {
    let raw = RawCreate { title: draftTitle, body: draftBody, lang: draftLang }
    match fromJson(api.CreateReq, toJson(raw)) {
        Valid(req) => api.createPaste(req, onCreatePaste),
        Invalid(iss) => setIssues(api.rpcIssuesFrom(iss)),
    }
}

/// Hand the pending soft-nav target to the host and clear it. The host polls this
/// after each render; a non-empty result triggers a navigation.
export extern fn takeNav() -> String {
    let target = navTarget
    navTarget = ""
    return target
}

/// The boot view as JSON for the host.
export extern fn vyrnView() -> String {
    return toJson(view())
}

/// The patch loop: only changed nodes cross the extern boundary.
export extern fn vyrnPatch() -> String {
    let next = view()
    let ops = diff(lastTree, next)
    lastTree = next
    return toJson(ops)
}

fn main() -> Int64 {
    return 0
}

test "submitCreate surfaces accumulated Issues for an invalid draft (no trap)" {
    let raw = RawCreate { title: "t", body: "", lang: "klingon" }
    match fromJson(api.CreateReq, toJson(raw)) {
        Valid(req) => assert(false),
        Invalid(iss) => assert(iss.length >= 1),
    }
}

test "a valid draft decodes to a CreateReq" {
    let raw = RawCreate { title: "hi", body: "some body", lang: "vyrn" }
    match fromJson(api.CreateReq, toJson(raw)) {
        Valid(req) => assertEq(req.lang, "vyrn"),
        Invalid(iss) => assert(false),
    }
}

test "createForm renders the heading and save button (a .vyx view snapshot)" {
    let html = toHtmlString(createForm("", "text", "", []))
    // The labels resolve inside the widget (its own i18n import, default En).
    assert(html.contains("New paste"))
    assert(html.contains("Create paste"))
}

test "createForm attaches the localized body issue under its field, not the leaked type name" {
    // A real prevalidation of an empty body, mapped to the one RpcIssue shape.
    let raw = RawCreate { title: "t", body: "", lang: "text" }
    let iss = match fromJson(api.CreateReq, toJson(raw)) {
        Valid(req) => api.rpcIssuesFrom([]),
        Invalid(is) => api.rpcIssuesFrom(is),
    }
    assert(iss.length >= 1)
    let html = toHtmlString(createForm("t", "text", "", iss))
    // Localized + field-attached (the widget's own i18n import, default En).
    assert(html.contains("Body can't be empty"))
    // The wire-canonical leaked type name never reaches the UI for a known path.
    assert(html.contains("validation failed for `Body`") == false)
}

test "a bad lang value attaches its own localized message under the language field" {
    let iss = api.rpcIssuesFrom([Issue { key: "validate", path: "lang", message: "validation failed for `Lang`" }])
    let html = toHtmlString(createForm("t", "klingon", "b", iss))
    assert(html.contains("Choose a supported language"))
    assert(html.contains("validation failed for `Lang`") == false)
}

test "an issue at an unknown path falls back to its wire message (form-level, never nothing)" {
    let iss = api.rpcIssuesFrom([Issue { key: "validate", path: "mystery", message: "unmapped problem" }])
    let html = toHtmlString(createForm("t", "text", "b", iss))
    // An unknown path is no field's span; it degrades to today's wire text.
    assert(html.contains("unmapped problem"))
}
