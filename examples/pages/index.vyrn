/// The home page — a static route (`GET /`). No dynamic segments and no loader,
/// so it exports the nullary form `fn page() -> Html`.
import { el, text, Html } from "std/html"

export fn page() -> Html {
    return el("main", [], [
            el("h1", [], [text("Home")]),
            el("p", [], [text("Welcome to the std/ui pages demo (RFC-0026 M3).")]),
        ])
}
