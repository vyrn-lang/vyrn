// Recursive Fibonacci — exercises functions, recursion, if, and comparison.
// `velac run examples/fib.vela` prints 55 and exits with code 55.

fn fib(n: Int64) -> Int64 {
    if n < 2 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

fn main() -> Int64 {
    let result = fib(10)
    print(result)
    return result
}
