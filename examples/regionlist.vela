/// A growable array created from a literal *inside* a region: the buffer is
/// plain heap (push grows it with realloc), so it must never come from the
/// region arena — only the region's own strings do.

fn main() -> Int {
    let mut n = 0
    region {
        let mut a = list([1, 2])
        a = push(a, 3)
        a = push(a, 4)
        a = push(a, 5)
        n = at(a, 4)
    }
    return n
}
