/// The error model — RFC-0009. A structured, accumulating `Validation<T>`.
///
/// A validator collects EVERY failing check (not just the first) into an array of
/// `Issue`s, each carrying an i18n `key`, a field `path`, and a default `message`.
/// The caller can render them, or map the `key` to a localized string for i18n.
///
///   type Issue      = { key: String, path: String, message: String }
///   type Validation<T> = | Valid(T) | Invalid(Array<Issue>)

type Person = { name: String, age: Int64 }

fn validatePerson(name: String, age: Int64) -> Validation<Person> {
    let mut issues: Array<Issue> = []
    if name.len() == 0 {
        issues.push(Issue { key: "name.required", path: "name", message: "Name is required" })
    }
    if age < 0 {
        issues.push(Issue { key: "age.min", path: "age", message: "Age must be at least 0" })
    }
    if age > 150 {
        issues.push(Issue { key: "age.max", path: "age", message: "Age is implausible" })
    }
    if issues.length > 0 {
        return Invalid(issues)
    }
    return Valid(Person { name: name, age: age })
}

fn issuesOf(v: Validation<Person>) -> Array<Issue> {
    return match v {
        Valid(p) => [],
        Invalid(is) => is,
    }
}

// i18n: map an issue key to a localized message (here: German).
fn translateDe(key: String) -> String {
    if key == "name.required" { return "Name ist erforderlich" }
    if key == "age.min" { return "Alter muss mindestens 0 sein" }
    if key == "age.max" { return "Alter ist unplausibel" }
    return key
}

fn main() -> Int64 {
    // Two problems at once: empty name AND age out of range.
    let issues = issuesOf(validatePerson("", 200))
    print(issues.length)                 // 2

    for i in issues {
        // key + path (for programmatic handling) and a localized message (i18n).
        print("\{i.path}: \{translateDe(i.key)}")
    }
    // name: Name ist erforderlich
    // age: Alter ist unplausibel

    return issues.length
}
