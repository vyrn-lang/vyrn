{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "User",
    "type": "object",
    "properties": {
        "name": {"type": "string", "minLength": 3, "maxLength": 16},
        "age": {"type": "integer", "minimum": 18, "maximum": 130},
        "nick": {"type": "string"}
    },
    "required": ["name", "age"],
    "$defs": {
        "Port": {"type": "integer", "minimum": 1, "maximum": 65535}
    }
}
