{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vyx",
  "scopeName": "source.vyx",
  "patterns": [
    { "include": "#script-section" },
    { "include": "#template-section" }
  ],
  "repository": {
    "script-section": {
      "comment": "The <script> block holds ordinary Vyrn (props/params, imports, helpers).",
      "begin": "(<)(script)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vyx" },
        "2": { "name": "entity.name.tag.script.vyx" },
        "3": { "name": "punctuation.definition.tag.end.vyx" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vyx" },
        "2": { "name": "entity.name.tag.script.vyx" },
        "3": { "name": "punctuation.definition.tag.end.vyx" }
      },
      "patterns": [
        { "match": "^\\s*(props|params)\\b", "captures": { "1": { "name": "keyword.control.props.vyx" } } },
        { "include": "source.vyrn" }
      ]
    },
    "template-section": {
      "begin": "(<)(template)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vyx" },
        "2": { "name": "entity.name.tag.template.vyx" },
        "3": { "name": "punctuation.definition.tag.end.vyx" }
      },
      "end": "(</)(template)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vyx" },
        "2": { "name": "entity.name.tag.template.vyx" },
        "3": { "name": "punctuation.definition.tag.end.vyx" }
      },
      "patterns": [{ "include": "#template-body" }]
    },
    "template-body": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#interp" },
        { "include": "#component-tag" },
        { "include": "#element-tag" }
      ]
    },
    "comments": {
      "begin": "<!--",
      "end": "-->",
      "name": "comment.block.vyx"
    },
    "interp": {
      "comment": "{{ expr }} — an escaped interpolation carrying a Vyrn expression (RFC-0039 v2).",
      "begin": "\\{\\{",
      "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.vyx" } },
      "end": "\\}\\}",
      "endCaptures": { "0": { "name": "punctuation.section.embedded.end.vyx" } },
      "patterns": [{ "include": "source.vyrn" }]
    },
    "component-tag": {
      "comment": "A <Capitalized> sibling-component call.",
      "begin": "(</?)([A-Z][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vyx" },
        "2": { "name": "entity.name.type.component.vyx" }
      },
      "end": "(/?>)",
      "endCaptures": { "1": { "name": "punctuation.definition.tag.end.vyx" } },
      "patterns": [{ "include": "#attributes" }]
    },
    "element-tag": {
      "comment": "An ordinary lowercase HTML element (incl. <slot/>).",
      "begin": "(</?)([a-z][A-Za-z0-9_-]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.vyx" },
        "2": { "name": "entity.name.tag.vyx" }
      },
      "end": "(/?>)",
      "endCaptures": { "1": { "name": "punctuation.definition.tag.end.vyx" } },
      "patterns": [{ "include": "#attributes" }]
    },
    "attributes": {
      "patterns": [
        {
          "comment": "v-if / v-else-if / v-for / v-html with a double-quoted Vyrn expression (RFC-0039 v2).",
          "begin": "(v-if|v-else-if|v-for|v-html)(=)(\")",
          "beginCaptures": {
            "1": { "name": "keyword.control.directive.vyx" },
            "2": { "name": "punctuation.separator.key-value.vyx" },
            "3": { "name": "punctuation.definition.string.begin.vyx" }
          },
          "end": "\"",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.vyx" } },
          "patterns": [
            { "match": "\\bin\\b", "name": "keyword.control.flow.vyx" },
            { "include": "source.vyrn" }
          ]
        },
        {
          "comment": "v-if / v-else-if / v-for / v-html with a single-quoted expression.",
          "begin": "(v-if|v-else-if|v-for|v-html)(=)(')",
          "beginCaptures": {
            "1": { "name": "keyword.control.directive.vyx" },
            "2": { "name": "punctuation.separator.key-value.vyx" },
            "3": { "name": "punctuation.definition.string.begin.vyx" }
          },
          "end": "'",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.vyx" } },
          "patterns": [
            { "match": "\\bin\\b", "name": "keyword.control.flow.vyx" },
            { "include": "source.vyrn" }
          ]
        },
        {
          "comment": "v-else — the bare chain directive.",
          "match": "\\bv-else\\b",
          "name": "keyword.control.directive.vyx"
        },
        {
          "comment": "@event=\"handler(arg)\" — an event binding with a Vyrn expression.",
          "begin": "(@[a-z]+)(=)(\")",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.event.vyx" },
            "2": { "name": "punctuation.separator.key-value.vyx" },
            "3": { "name": "punctuation.definition.string.begin.vyx" }
          },
          "end": "\"",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.vyx" } },
          "patterns": [{ "include": "source.vyrn" }]
        },
        {
          "comment": "@event='handler(arg)' — single-quoted event binding.",
          "begin": "(@[a-z]+)(=)(')",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.event.vyx" },
            "2": { "name": "punctuation.separator.key-value.vyx" },
            "3": { "name": "punctuation.definition.string.begin.vyx" }
          },
          "end": "'",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.vyx" } },
          "patterns": [{ "include": "source.vyrn" }]
        },
        {
          "comment": ":attr=\"expr\" — a dynamic attribute (incl. :key, :class) with a Vyrn expression.",
          "begin": "(:[A-Za-z_][A-Za-z0-9_-]*)(=)(\")",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.dynamic.vyx" },
            "2": { "name": "punctuation.separator.key-value.vyx" },
            "3": { "name": "punctuation.definition.string.begin.vyx" }
          },
          "end": "\"",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.vyx" } },
          "patterns": [{ "include": "source.vyrn" }]
        },
        {
          "comment": ":attr='expr' — single quotes let the expression carry Vyrn string literals.",
          "begin": "(:[A-Za-z_][A-Za-z0-9_-]*)(=)(')",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.dynamic.vyx" },
            "2": { "name": "punctuation.separator.key-value.vyx" },
            "3": { "name": "punctuation.definition.string.begin.vyx" }
          },
          "end": "'",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.vyx" } },
          "patterns": [{ "include": "source.vyrn" }]
        },
        {
          "comment": "attr=\"literal\" — a static attribute value.",
          "match": "([A-Za-z_][A-Za-z0-9_-]*)(=)(\"[^\"]*\"|'[^']*')",
          "captures": {
            "1": { "name": "entity.other.attribute-name.vyx" },
            "2": { "name": "punctuation.separator.key-value.vyx" },
            "3": { "name": "string.quoted.vyx" }
          }
        },
        { "match": "\\b[A-Za-z_][A-Za-z0-9_-]*\\b", "name": "entity.other.attribute-name.vyx" }
      ]
    }
  }
}
